<Window x:Class="TerminalLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:ctrl="clr-namespace:TerminalLauncher.Controls"
        xmlns:loc="clr-namespace:TerminalLauncher.Services"
        Title="مشغّل الأوامر" Height="700" Width="1120"
        Icon="pack://application:,,,/Assets/AppIcon/app.ico"
        MinHeight="480" MinWidth="820"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" Background="{DynamicResource Brush.Bg}"
        TextOptions.TextFormattingMode="Ideal"
        FontFamily="{DynamicResource Font.Ui}" FontSize="{DynamicResource Size.Ui}"
        Foreground="{DynamicResource Brush.Text}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="46" ResizeBorderThickness="8"
                            CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border x:Name="RootBorder" Background="{DynamicResource Brush.Bg}" CornerRadius="6" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="46"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- طبقة تعتيم شريط العنوان: شبه شفّافة حسب الثيم كي يبقى العنوان/الأزرار ظاهرين فوق صورة
                 الخلفيّة. تُفعَّل فقط مع خلفيّة مخصّصة (تُضبَط في ApplyBackground)، وإلّا شفّافة تماماً. -->
            <Border x:Name="AppHeaderScrim" Grid.Row="0" Background="Transparent"/>

            <!-- ===== شريط العنوان ===== -->
            <Grid Grid.Row="0" Margin="14,0,8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <!-- زرّ إظهار/إخفاء شريط الأوامر المحفوظة (أيقونة لوحة جانبيّة تتبع لون الزرّ) -->
                    <Button x:Name="SidebarToggleButton" Style="{StaticResource ChromeButton}"
                            Click="SidebarToggleButton_Click" Margin="0,0,4,0"
                            ToolTip="إظهار/إخفاء الأوامر المحفوظة">
                        <Grid Width="16" Height="13" FlowDirection="LeftToRight" ClipToBounds="True">
                            <Border BorderThickness="1.4" CornerRadius="3"
                                    BorderBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            <Border Width="5.5" HorizontalAlignment="Left" CornerRadius="3,0,0,3"
                                    Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        </Grid>
                    </Button>
                    <Border Width="26" Height="26" CornerRadius="7" Background="{DynamicResource Brush.Accent}">
                        <TextBlock Text="&#xE756;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource Brush.OnAccent}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="TitleText" Text="مشغّل الأوامر" FontWeight="SemiBold" FontSize="13.5"
                               VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>

                <!-- حقل البحث المركزيّ: نقطة الدخول الوحيدة للمشاريع والأوامر — يعكس نصّه على بحث
                     اللوحة الجانبيّة ويفتحها تلقائياً، فلا يوجد حقلا بحث منفصلان بحالتين. -->
                <TextBox x:Name="HeaderSearch" Grid.Column="1" Style="{StaticResource SearchPill}"
                         MaxWidth="420" HorizontalAlignment="Center" VerticalAlignment="Center"
                         MinWidth="240" Margin="16,0"
                         shell:WindowChrome.IsHitTestVisibleInChrome="True"
                         TextChanged="HeaderSearch_TextChanged" GotKeyboardFocus="HeaderSearch_GotFocus"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="NewTabButton" Style="{StaticResource ChromeButton}"
                            Content="&#xE710;" Click="NewTabButton_Click"
                            ToolTip="تيرمنال فارغ جديد (Ctrl+Shift+T)"/>
                    <Button x:Name="NewTabDropDown" Style="{StaticResource ChromeButton}"
                            Content="&#xE70D;" FontSize="10" Click="NewTabDropDown_Click"
                            ToolTip="اختر بروفايل صدفة"/>
                    <Button x:Name="ServerMonitorButton" Style="{StaticResource ChromeButton}"
                            Content="&#xE968;" Click="ToolsButton_Click" ToolTip="أدوات النظام">
                        <Button.ContextMenu>
                            <ContextMenu x:Name="ToolsMenu">
                                <MenuItem x:Name="ToolServerMonitor" Header="مراقب الخوادم"
                                          Click="ServerMonitorButton_Click">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource Size.MenuIcon}"
                                                   Foreground="{DynamicResource Brush.Accent}"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button x:Name="WhatsNewButton" Style="{StaticResource ChromeButton}"
                            Content="&#xE946;" Click="WhatsNewButton_Click" ToolTip="ما الجديد / حول البرنامج"/>
                    <Button x:Name="SettingsButton" Style="{StaticResource ChromeButton}"
                            Content="&#xE713;" Click="SettingsButton_Click" ToolTip="الإعدادات"/>
                    <Button x:Name="MinButton" Style="{StaticResource ChromeButton}"
                            Content="&#xE921;" Click="MinButton_Click"/>
                    <Button x:Name="MaxButton" Style="{StaticResource ChromeButton}"
                            Content="&#xE922;" Click="MaxButton_Click"/>
                    <Button x:Name="CloseButton" Style="{StaticResource ChromeCloseButton}"
                            Content="&#xE8BB;" Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>

            <!-- ===== المحتوى ===== (بلا هامش: التيرمنال يملأ حتى حافّة النافذة) -->
            <Grid x:Name="ContentGrid" Grid.Row="1" Margin="0">
                <Grid.ColumnDefinitions>
                    <!-- عرض الشريط الجانبيّ: 280 موسَّعاً (الافتراضي) · 60 مطويّاً — يضبطه SetSidebarExpanded -->
                    <ColumnDefinition x:Name="SidebarCol" Width="280"/>
                    <ColumnDefinition x:Name="SplitterCol" Width="0"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- الحالة المطويّة للشريط الجانبيّ: أيقونات فقط (60px). تتبادل الظهور مع SidebarPanel
                     الموسَّع في العمود نفسه — لا تظهران معاً. الشريط يطفو فوق الخلفيّة بلا بطاقة ولا حدّ. -->
                <Border x:Name="SidebarRail" Grid.Column="0" Background="Transparent"
                        BorderThickness="0" CornerRadius="{DynamicResource Radius.Card}" Padding="0"
                        Visibility="Collapsed">
                    <DockPanel Margin="0,8">
                        <Button x:Name="SidebarMenuBtn" DockPanel.Dock="Top" Style="{StaticResource IconButton}"
                                Content="&#xE712;" FontFamily="Segoe MDL2 Assets" FontSize="16" Height="38"
                                Foreground="{DynamicResource Brush.Text}" Click="SidebarMenu_Click"
                                ToolTip="الأوامر المحفوظة"/>
                        <Button x:Name="SidebarAddBtn" DockPanel.Dock="Top" Style="{StaticResource IconButton}"
                                Content="＋" FontSize="20" Height="38"
                                Foreground="{DynamicResource Brush.Accent}" Click="AddButton_Click" ToolTip="إضافة أمر"/>
                        <Border DockPanel.Dock="Top" Height="1" Margin="14,8" Background="{DynamicResource Brush.Hairline}"/>
                        <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="SidebarDots">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Margin="0,4" Width="36" Height="36" Cursor="Hand" HorizontalAlignment="Center"
                                                Tag="{Binding}" Click="SidebarDot_Click" ToolTip="{Binding Name}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <!-- مربّع المشروع: ممتلئ بلون المشروع مع الحرف الأوّل -->
                                                    <Border x:Name="d" Width="32" Height="32" CornerRadius="{DynamicResource Radius.Card}"
                                                            Background="{Binding Name, Converter={StaticResource Conv.PrimaryTagBrush}}"
                                                            BorderBrush="Transparent" BorderThickness="0"
                                                            ClipToBounds="True">
                                                        <TextBlock Text="{Binding Initial}" HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center" FontWeight="Bold" FontSize="13"
                                                                   Foreground="#FFFFFF"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="d" Property="BorderBrush" Value="{DynamicResource Brush.Text}"/>
                                                            <Setter TargetName="d" Property="BorderThickness" Value="2"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!-- منطقة التيرمنالات -->
                <Grid Grid.Column="2">
                    <!-- لوحة البداية: بطاقة مرسوّة أسفل منطقة التيرمنال (لا في وسطها) تسرد اختصارات
                         البدء صفّاً صفّاً برقاقات كيبورد — كما في التصميم المرجعيّ. تختفي مع أوّل تبويب. -->
                    <Border x:Name="EmptyHintCard" Style="{StaticResource Card}"
                            VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
                            Margin="0,0,0,10" Padding="18,16">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="&#xE756;" FontFamily="Segoe MDL2 Assets" FontSize="15"
                                           VerticalAlignment="Center" Margin="0,0,9,0"
                                           Foreground="{DynamicResource Brush.Accent}"/>
                                <TextBlock x:Name="HintLine1" Text="جلسة تيرمنال جديدة"
                                           FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- كلّ صفّ: رقاقات الاختصار ثمّ وصفه. الرقاقات LTR دائماً (رموز كيبورد). -->
                            <Grid x:Name="HintRows">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal"
                                            FlowDirection="LeftToRight" Margin="0,0,10,6">
                                    <Border Style="{StaticResource KeyCap}"><TextBlock Text="ctrl" Style="{StaticResource KeyCapText}"/></Border>
                                    <Border Style="{StaticResource KeyCap}"><TextBlock Text="shift" Style="{StaticResource KeyCapText}"/></Border>
                                    <Border Style="{StaticResource KeyCap}"><TextBlock Text="T" Style="{StaticResource KeyCapText}"/></Border>
                                </StackPanel>
                                <TextBlock x:Name="HintLine2" Grid.Row="0" Grid.Column="1" Text="تيرمنال فارغ"
                                           VerticalAlignment="Center" Margin="0,0,0,6"
                                           FontSize="{DynamicResource Size.Small}"
                                           Foreground="{DynamicResource Brush.TextMuted}"/>

                                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal"
                                            FlowDirection="LeftToRight" Margin="0,0,10,6">
                                    <Border Style="{StaticResource KeyCap}"><TextBlock Text="ctrl" Style="{StaticResource KeyCapText}"/></Border>
                                    <Border Style="{StaticResource KeyCap}"><TextBlock Text="shift" Style="{StaticResource KeyCapText}"/></Border>
                                    <Border Style="{StaticResource KeyCap}"><TextBlock Text="P" Style="{StaticResource KeyCapText}"/></Border>
                                </StackPanel>
                                <TextBlock x:Name="HintLine3" Grid.Row="1" Grid.Column="1" Text="لوحة الأوامر"
                                           VerticalAlignment="Center" Margin="0,0,0,6"
                                           FontSize="{DynamicResource Size.Small}"
                                           Foreground="{DynamicResource Brush.TextMuted}"/>

                                <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal"
                                            FlowDirection="LeftToRight" Margin="0,0,10,6">
                                    <Border Style="{StaticResource KeyCap}"><TextBlock Text="ctrl" Style="{StaticResource KeyCapText}"/></Border>
                                    <Border Style="{StaticResource KeyCap}"><TextBlock Text="shift" Style="{StaticResource KeyCapText}"/></Border>
                                    <Border Style="{StaticResource KeyCap}"><TextBlock Text="D" Style="{StaticResource KeyCapText}"/></Border>
                                </StackPanel>
                                <TextBlock x:Name="HintLine4" Grid.Row="2" Grid.Column="1" Text="انقسام جنباً لجنب"
                                           VerticalAlignment="Center" Margin="0,0,0,6"
                                           FontSize="{DynamicResource Size.Small}"
                                           Foreground="{DynamicResource Brush.TextMuted}"/>

                                <StackPanel Grid.Row="3" Grid.Column="0" Orientation="Horizontal"
                                            FlowDirection="LeftToRight" Margin="0,0,10,0">
                                    <Border Style="{StaticResource KeyCap}"><TextBlock Text="ctrl" Style="{StaticResource KeyCapText}"/></Border>
                                    <Border Style="{StaticResource KeyCap}"><TextBlock Text="shift" Style="{StaticResource KeyCapText}"/></Border>
                                    <Border Style="{StaticResource KeyCap}"><TextBlock Text="E" Style="{StaticResource KeyCapText}"/></Border>
                                </StackPanel>
                                <TextBlock x:Name="HintLine5" Grid.Row="3" Grid.Column="1" Text="انقسام فوق/تحت"
                                           VerticalAlignment="Center"
                                           FontSize="{DynamicResource Size.Small}"
                                           Foreground="{DynamicResource Brush.TextMuted}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <TabControl x:Name="TerminalTabs" PreviewMouseDown="TerminalTabs_PreviewMouseDown"/>
                </Grid>

                <!-- ===== لوحة المشاريع الدائمة (الحالة الموسَّعة للشريط الجانبيّ) =====
                     مرسوّة في العمود ٠ لا طافيةً فوق المحتوى: القائمة حاضرة دائماً كما في التصميم
                     المرجعيّ، والطيّ يصغّر العمود إلى الشريط الأيقونيّ بدل إخفاء كلّ شيء. -->
                <Border x:Name="SidebarPanel" Grid.Column="0" VerticalAlignment="Stretch">
                    <Border Style="{StaticResource Card}" Padding="12">
                        <DockPanel>
                            <Grid DockPanel.Dock="Top" Margin="2,0,0,10">
                                <TextBlock x:Name="SidebarHeader" Text="الأوامر المحفوظة" FontWeight="SemiBold" FontSize="14"
                                           VerticalAlignment="Center"/>
                                <Button HorizontalAlignment="Right" Style="{StaticResource IconButton}"
                                        Content="＋" FontSize="19" Foreground="{DynamicResource Brush.Accent}"
                                        Click="AddButton_Click" ToolTip="إضافة أمر"/>
                            </Grid>

                            <!-- نفس حبّة بحث الرأس: عدسة + نصّ بديل (الحقل العادي كان يظهر صندوقاً فارغاً
                                 بلا أيّ دلالة لأنّ الستايل الضمنيّ لا يرسم Tag كنصّ بديل). -->
                            <TextBox x:Name="SidebarSearch" DockPanel.Dock="Top" Margin="0,0,0,10"
                                     Style="{StaticResource SearchPill}"
                                     TextChanged="SidebarSearch_TextChanged"/>

                            <!-- مقطع «الإعدادات» أسفل اللوحة: عنوان مكتوم صغير + صفّ واحد — نفس بنية
                                 المقاطع في التصميم المرجعيّ (بلا خطّ فاصل). -->
                            <StackPanel DockPanel.Dock="Bottom">
                                <TextBlock x:Name="SidebarSettingsCaption" Text="الإعدادات"
                                           Style="{StaticResource Caption}"/>
                                <Button x:Name="SidebarSettingsBtn" Click="SettingsButton_Click"
                                        HorizontalContentAlignment="Stretch" Background="Transparent"
                                        BorderThickness="0" Padding="10,8">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                   VerticalAlignment="Center" Margin="0,0,10,0"
                                                   Foreground="{DynamicResource Brush.TextMuted}"/>
                                        <TextBlock x:Name="SidebarSettingsText" Text="الإعدادات"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>


                            <!-- شريط فلترة التاكات: «الكل» + رقاقة لكل تاك — صفّ أفقيّ بسكرول مربوط بالعجلة -->
                            <ScrollViewer x:Name="ProjectFilterScroll" DockPanel.Dock="Top"
                                          HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                          Margin="0,0,0,8" Visibility="Collapsed"
                                          PreviewMouseWheel="HorizontalChips_PreviewMouseWheel">
                                <ScrollViewer.Resources>
                                    <Style TargetType="ScrollBar" BasedOn="{StaticResource ThemedScrollBar}"/>
                                </ScrollViewer.Resources>
                                <StackPanel x:Name="ProjectFilterBar" Orientation="Horizontal"/>
                            </ScrollViewer>

                            <Button x:Name="RunBtn" DockPanel.Dock="Bottom" Margin="0,10,0,0" Style="{StaticResource AccentButton}"
                                    Content="&#x25B6;  فتح المشروع" Click="RunButton_Click"/>

                            <ListBox x:Name="EntriesList" Margin="0,0,0,2"
                                     MouseDoubleClick="EntriesList_MouseDoubleClick"
                                     PreviewMouseRightButtonDown="EntriesList_PreviewMouseRightButtonDown">
                                <ListBox.Resources>
                                    <!-- شريط تمرير متوافق مع الثيم (بدل الافتراضيّ) — مثل بقيّة القوائم -->
                                    <Style TargetType="ScrollBar" BasedOn="{StaticResource ThemedScrollBar}"/>
                                </ListBox.Resources>
                                <!-- قائمة المشروع السياقيّة تُبنى في الكود (BuildProjectContextMenu) لأنّها
                                     تتضمّن صفّ ألوان ديناميكيّاً وحالةً تتغيّر حسب المشروع المحدَّد. -->
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2,0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- رقاقة المشروع: مربّع ملوّن بالحرف الأوّل بدل النقطة الصغيرة —
                                                 يعطي الصفّ مرساةً بصريّة ويوازن السطرين. -->
                                            <Border Grid.Column="0" Width="26" Height="26"
                                                    CornerRadius="{DynamicResource Radius.Control}"
                                                    Margin="0,0,10,0" VerticalAlignment="Center"
                                                    Background="{Binding Name, Converter={StaticResource Conv.PrimaryTagBrush}}">
                                                <TextBlock Text="{Binding Initial}" Foreground="#FFFFFF"
                                                           FontWeight="SemiBold" FontSize="12"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontSize="{DynamicResource Size.Ui}"
                                                           FontFamily="{DynamicResource Font.Mono}"
                                                           HorizontalAlignment="Left" TextTrimming="CharacterEllipsis"/>
                                                <!-- LTR content (filesystem path); HorizontalAlignment mirrors with the
                                                     parent's flow so both lines share the same start edge. -->
                                                <TextBlock Text="{Binding Folder}" FontSize="{DynamicResource Size.Small}"
                                                           Foreground="{DynamicResource Brush.TextMuted}"
                                                           HorizontalAlignment="Left" Margin="0,1,0,0"
                                                           FlowDirection="LeftToRight" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <Border Grid.Column="2" CornerRadius="{DynamicResource Radius.Control}" Padding="7,1" VerticalAlignment="Center"
                                                    Background="{DynamicResource Brush.KeyCap}">
                                                <TextBlock Text="{Binding Commands.Count}" FontSize="{DynamicResource Size.Small}"
                                                           Foreground="{DynamicResource Brush.TextMuted}"/>
                                            </Border>
                                            <!-- زرّ الثلاث نقاط: يظهر عند المرور ويفتح قائمة الصفّ (فتح/تعديل/حذف) -->
                                            <Button Grid.Column="3" Margin="4,0,0,0" VerticalAlignment="Center"
                                                    ctrl:MenuButton.IsMenuTrigger="True">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource KebabButton}">
                                                        <Setter Property="Visibility" Value="Hidden"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>
                </Border>

                <!-- ===== لوحة أوامر المشروع السريعة: تطفو شفّافة على حافة التيرمنال (فوق طبقة اللوحة المنبثقة) ===== -->
                <Border x:Name="QuickDock" Grid.Column="2" Visibility="Collapsed" Width="234"
                        HorizontalAlignment="Left" VerticalAlignment="Stretch"
                        Margin="6" CornerRadius="{DynamicResource Radius.Card}"
                        Background="{DynamicResource Brush.SurfaceGlass}"
                        BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" BlurRadius="22" ShadowDepth="0" Opacity="0.4"/>
                    </Border.Effect>
                    <DockPanel>
                        <!-- الرأس: نقطة لون + اسم المشروع + تعديل + طيّ، وسطر الفولدر -->
                        <Grid DockPanel.Dock="Top" Margin="11,10,7,7">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <Border x:Name="QuickDockDot" Width="9" Height="9" CornerRadius="5"
                                        Margin="0,0,7,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="QuickDockTitle" FontSize="{DynamicResource Size.Ui}" FontWeight="SemiBold"
                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button x:Name="QuickEditProject" Style="{StaticResource IconButton}"
                                        Width="26" Height="26" Content="&#xE70F;" FontFamily="Segoe MDL2 Assets"
                                        FontSize="11" Foreground="{DynamicResource Brush.TextMuted}"
                                        Click="QuickEditProject_Click" ToolTip="تعديل المشروع"/>
                                <Button Style="{StaticResource IconButton}"
                                        Width="26" Height="26" Content="&#xE89F;" FontFamily="Segoe MDL2 Assets"
                                        FontSize="11" Foreground="{DynamicResource Brush.TextMuted}"
                                        Click="QuickDockClose_Click" ToolTip="طيّ اللوحة"/>
                            </StackPanel>
                            <Border Grid.Row="1" Grid.ColumnSpan="2" Margin="0,5,0,0" CornerRadius="6" Padding="7,3"
                                    Background="{DynamicResource Brush.Bg}" Cursor="Hand"
                                    ToolTip="فولدر المشروع" MouseLeftButtonUp="QuickEditProject_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource Size.Small}"
                                               Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center"
                                               Margin="0,0,6,0"/>
                                    <TextBlock x:Name="QuickDockPath" FontSize="{DynamicResource Size.Small}" FlowDirection="LeftToRight"
                                               Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" MaxWidth="180"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- رقاقات تبديل المشاريع: صفّ أفقيّ بسكرول قابل للسحب ومربوط بعجلة الماوس/الباد -->
                        <ScrollViewer DockPanel.Dock="Top" HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled" Margin="9,0,9,5"
                                      PreviewMouseWheel="HorizontalChips_PreviewMouseWheel">
                            <ScrollViewer.Resources>
                                <Style TargetType="ScrollBar" BasedOn="{StaticResource ThemedScrollBar}"/>
                            </ScrollViewer.Resources>
                            <StackPanel x:Name="QuickDockChips" Orientation="Horizontal"/>
                        </ScrollViewer>

                        <Border DockPanel.Dock="Top" Height="1" Margin="9,0,9,0"
                                Background="{DynamicResource Brush.Border}"/>

                        <!-- التذييل: أمر جديد + التقاط الأمر الحاليّ -->
                        <StackPanel DockPanel.Dock="Bottom" Margin="9,6,9,9">
                            <Button x:Name="QuickNewCommand" Style="{StaticResource AccentButton}"
                                    Click="QuickNewCommand_Click"/>
                            <Button x:Name="QuickAddCurrent" Margin="0,6,0,0" Padding="10,6"
                                    Click="QuickAddCurrent_Click"/>
                        </StackPanel>

                        <!-- الجسم: أوامر المشروع (+ محرّر مباشر يُبنى في الكود) -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                      Margin="0,7,0,0">
                            <ScrollViewer.Resources>
                                <Style TargetType="ScrollBar" BasedOn="{StaticResource ThemedScrollBar}"/>
                            </ScrollViewer.Resources>
                            <StackPanel Margin="9,0,9,4">
                                <StackPanel x:Name="QuickCmdPanel"/>
                                <TextBlock x:Name="QuickCmdEmpty" FontSize="{DynamicResource Size.Small}" TextWrapping="Wrap"
                                           Foreground="{DynamicResource Brush.TextMuted}" Margin="2,2,2,4"
                                           Visibility="Collapsed"/>
                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!-- ===== محرّر المشروع (اسم/لون/فولدر/صدفة) ===== -->
                <Border x:Name="ProjectEditorOverlay" Grid.ColumnSpan="3" Background="#88000000"
                        Visibility="Collapsed" MouseLeftButtonDown="ProjectEditorOverlay_MouseDown">
                    <Border Width="440" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Style="{StaticResource Card}" Padding="20" MouseLeftButtonDown="EditorCard_MouseDown">
                        <StackPanel>
                            <TextBlock x:Name="ProjEditTitle" Text="مشروع جديد" FontSize="16" FontWeight="SemiBold"
                                       Margin="0,0,0,14"/>
                            <TextBlock x:Name="ProjEditNameLabel" Text="الاسم" Style="{StaticResource SectionLabel}"/>
                            <TextBox x:Name="ProjEditName"/>

                            <TextBlock x:Name="ProjEditTagsLabel" Text="التاكات (تصنيفات ملوّنة)" Style="{StaticResource SectionLabel}" Margin="2,12,2,6"/>
                            <WrapPanel x:Name="ProjEditTagPanel"/>
                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="ProjNewTagColorDot" Grid.Column="0" Width="30" Height="30"
                                        CornerRadius="8" Margin="0,0,6,0" Cursor="Hand"
                                        BorderThickness="1" BorderBrush="{DynamicResource Brush.Border}"
                                        MouseLeftButtonUp="ProjNewTagColorDot_Click" ToolTip="لون التاك الجديد"/>
                                <TextBox x:Name="ProjEditNewTag" Grid.Column="1" VerticalContentAlignment="Center"
                                         KeyDown="ProjEditNewTag_KeyDown" ToolTip="اكتب اسم تاك جديد ثم Enter أو «إضافة»"/>
                                <Button Grid.Column="2" Content="＋ تاك" Margin="6,0,0,0" Padding="12,6"
                                        Click="ProjEditAddTag_Click"/>
                            </Grid>

                            <TextBlock x:Name="ProjEditFolderLabel" Text="الباث (مجلّد العمل)" Style="{StaticResource SectionLabel}" Margin="2,12,2,6"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="ProjEditFolder" FlowDirection="LeftToRight"/>
                                <Button Grid.Column="1" Content="&#xE838;" FontFamily="Segoe MDL2 Assets"
                                        Margin="6,0,0,0" Padding="10,6" Click="ProjEditBrowse_Click" ToolTip="استعراض"/>
                            </Grid>

                            <TextBlock x:Name="ProjEditShellLabel" Text="الصدفة الافتراضية" Style="{StaticResource SectionLabel}" Margin="2,12,2,6"/>
                            <ComboBox x:Name="ProjEditShell" DisplayMemberPath="Display" HorizontalAlignment="Left" Width="200"/>

                            <Grid Margin="0,20,0,0">
                                <Button x:Name="ProjEditCancelBtn" HorizontalAlignment="Left" Content="إلغاء" Padding="16,8"
                                        Click="ProjEditCancel_Click"/>
                                <Button x:Name="ProjEditSaveBtn" HorizontalAlignment="Right" Style="{StaticResource AccentButton}"
                                        Content="حفظ" Padding="20,8" Click="ProjEditSave_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- ===== شاشة الإعدادات (ملء النافذة، مقسَّمة فئات) ===== -->
                <Border x:Name="SettingsOverlay" Grid.ColumnSpan="3" Background="#66000000"
                        Visibility="Collapsed" FlowDirection="LeftToRight"
                        MouseLeftButtonDown="SettingsOverlay_MouseDown">
                    <Border x:Name="SettingsPanel" MaxWidth="1000" Width="Auto"
                            Margin="28" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                            CornerRadius="{DynamicResource Radius.Card}" Background="{DynamicResource Brush.SurfaceGlass}"
                            BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1"
                            RenderTransformOrigin="0.5,0.5" MouseLeftButtonDown="SettingsPanel_MouseDown">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="SettingsPanelTransform" ScaleX="0.96" ScaleY="0.96"/>
                        </Border.RenderTransform>
                        <DockPanel x:Name="SettingsContent" Margin="0" FlowDirection="RightToLeft">
                            <!-- الترويسة: عنوان + إغلاق -->
                            <Grid DockPanel.Dock="Top" Margin="24,20,20,16">
                                <TextBlock x:Name="SettingsTitle" Text="الإعدادات" FontSize="19"
                                           FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <Button HorizontalAlignment="Right" Style="{StaticResource ChromeButton}"
                                        Content="&#xE8BB;" Click="CloseSettings_Click"/>
                            </Grid>
                            <Border DockPanel.Dock="Top" Height="1" Margin="0,0,0,0"
                                    Background="{DynamicResource Brush.Border}"/>

                            <TextBlock x:Name="AutoSaveLabel" DockPanel.Dock="Bottom" VerticalAlignment="Bottom"
                                       Text="تُحفظ التفضيلات تلقائياً" FontSize="10.5" Margin="24,10,24,14"
                                       Foreground="{DynamicResource Brush.TextMuted}"/>

                            <!-- الجسم: قائمة فئات (يسار) + محتوى الفئة المختارة (يمين) -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="1"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- قائمة الفئات (RadioButton مجموعة واحدة → اختيار حصريّ) -->
                                <StackPanel x:Name="CategoryList" Grid.Column="0" Margin="14,16,14,0">
                                    <RadioButton x:Name="NavAppearance" GroupName="SettingsCat"
                                                 Style="{StaticResource SettingsNavButton}" Tag="appearance"
                                                 Content="المظهر والخلفية" Checked="CategoryNav_Checked" IsChecked="True"/>
                                    <RadioButton x:Name="NavBackground" GroupName="SettingsCat" Visibility="Collapsed"
                                                 Style="{StaticResource SettingsNavButton}" Tag="background"
                                                 Content="الخلفية" Checked="CategoryNav_Checked"/>
                                    <RadioButton x:Name="NavLanguage" GroupName="SettingsCat"
                                                 Style="{StaticResource SettingsNavButton}" Tag="language"
                                                 Content="اللغة والخطّ" Checked="CategoryNav_Checked"/>
                                    <RadioButton x:Name="NavFont" GroupName="SettingsCat" Visibility="Collapsed"
                                                 Style="{StaticResource SettingsNavButton}" Tag="font"
                                                 Content="الخطّ" Checked="CategoryNav_Checked"/>
                                </StackPanel>

                                <Border Grid.Column="1" Background="{DynamicResource Brush.Border}"/>

                                <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Margin="0,8,0,0" Padding="24,12,20,12">
                                    <ScrollViewer.Resources>
                                        <Style TargetType="ScrollBar" BasedOn="{StaticResource ThemedScrollBar}"/>
                                    </ScrollViewer.Resources>
                                    <!-- StackPanel (لا Grid) كي تتراصّ اللوحات المرئيّة عمودياً عند دمج صنفين
                                         (المظهر+الخلفية معاً، اللغة+الخطّ معاً) بدل أن تتراكب في خليّة واحدة. -->
                                    <StackPanel>
                                        <!-- ===== فئة: المظهر ===== -->
                                        <StackPanel x:Name="CatAppearance">
                                            <TextBlock x:Name="AppearanceLabel" Text="الثيم" Style="{StaticResource SectionLabel}"/>
                                            <TextBlock x:Name="ThemeHint" Text="اختر ثيماً — يُطبَّق فوراً"
                                                       Foreground="{DynamicResource Brush.TextMuted}" FontSize="11" Margin="2,0,2,10"/>
                                            <!-- بطاقات الثيمات تُبنى في الكود (BuildThemeCards): تُعرَض المجموعة
                                                 الأولى فقط هنا (عدّة في السطر عبر WrapPanel)، وزرّ «عرض الكلّ»
                                                 يفتح قائمة منبثقة ببقيّة الثيمات. -->
                                            <WrapPanel x:Name="ThemeCardPanel"/>
                                            <Button x:Name="ThemeMoreButton" Content="عرض كل الثيمات"
                                                    HorizontalAlignment="Left" Margin="2,4,0,0" Padding="14,7"
                                                    Click="ThemeMoreButton_Click"/>

                                            <!-- مزامنة الفاتح/الداكن مع النظام -->
                                            <CheckBox x:Name="SyncOsCheck" Style="{StaticResource AppCheckBox}"
                                                      Content="مزامنة الفاتح/الداكن مع النظام" Margin="2,10,2,0"
                                                      Checked="SyncOsCheck_Changed" Unchecked="SyncOsCheck_Changed"/>

                                            <TextBlock x:Name="TextColorLabel" Text="لون الكتابة" Style="{StaticResource SectionLabel}" Margin="2,22,2,8"/>
                                            <WrapPanel x:Name="TextColorPanel"/>
                                        </StackPanel>

                                        <!-- ===== فئة: الخلفية ===== -->
                                        <StackPanel x:Name="CatBackground" Visibility="Collapsed" Margin="0,22,0,0">
                                            <TextBlock x:Name="BgTemplatesLabel" Text="قوالب"
                                                       Style="{StaticResource SectionLabel}"/>
                                            <!-- معرض القوالب يُبنى في الكود (BuildBackgroundGallery) -->
                                            <WrapPanel x:Name="BgGalleryPanel" Margin="0,2,0,4"/>

                                            <TextBlock x:Name="BgCustomLabel" Text="صورة مخصّصة"
                                                       Style="{StaticResource SectionLabel}" Margin="2,18,2,8"/>
                                            <StackPanel Orientation="Horizontal">
                                                <Button x:Name="BgChooseButton" Content="اختر صورة" Padding="14,7"
                                                        Click="BgChooseButton_Click"/>
                                                <Button x:Name="BgClearButton" Content="إزالة" Padding="14,7" Margin="8,0,0,0"
                                                        Click="BgClearButton_Click"/>
                                            </StackPanel>
                                            <TextBlock x:Name="BgPathText" FontSize="10.5" Margin="2,6,2,0"
                                                       TextTrimming="CharacterEllipsis" FlowDirection="LeftToRight"
                                                       Foreground="{DynamicResource Brush.TextMuted}"/>

                                            <TextBlock x:Name="BgOpacityLabel" Text="شفافية التيرمنال"
                                                       Style="{StaticResource SectionLabel}" Margin="2,18,2,8"/>
                                            <Grid FlowDirection="LeftToRight" Width="360" HorizontalAlignment="Left">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Slider x:Name="BgOpacitySlider" VerticalAlignment="Center"
                                                        Style="{StaticResource AccentSlider}"
                                                        Minimum="0.30" Maximum="1.00"
                                                        ValueChanged="BgOpacitySlider_ValueChanged"/>
                                                <TextBlock x:Name="BgOpacityValue" Grid.Column="1" MinWidth="34" Margin="10,0,0,0"
                                                           VerticalAlignment="Center" TextAlignment="Center"
                                                           Foreground="{DynamicResource Brush.TextMuted}"/>
                                            </Grid>
                                        </StackPanel>

                                        <!-- ===== فئة: اللغة ===== -->
                                        <StackPanel x:Name="CatLanguage" Visibility="Collapsed">
                                            <TextBlock x:Name="LangLabel" Text="اللغة" Style="{StaticResource SectionLabel}"/>
                                            <Border CornerRadius="9" Padding="4" MaxWidth="360" HorizontalAlignment="Left"
                                                    Background="{DynamicResource Brush.Bg}"
                                                    BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ToggleButton x:Name="ArToggle" Grid.Column="0" Style="{StaticResource SegToggle}"
                                                                  Content="عربي" Click="ArToggle_Click"/>
                                                    <ToggleButton x:Name="EnToggle" Grid.Column="1" Style="{StaticResource SegToggle}"
                                                                  Content="English" Click="EnToggle_Click"/>
                                                </Grid>
                                            </Border>
                                        </StackPanel>

                                        <!-- ===== فئة: الخطّ ===== -->
                                        <StackPanel x:Name="CatFont" Visibility="Collapsed" Margin="0,22,0,0">
                                            <!-- صندوق التأليف المنفصل (نمط Warp) -->
                                            <CheckBox x:Name="ComposerCheck" Style="{StaticResource AppCheckBox}"
                                                      Content="صندوق إدخال غنيّ منفصل (نمط Warp)" Margin="2,0,2,4"
                                                      Checked="ComposerCheck_Changed" Unchecked="ComposerCheck_Changed"/>
                                            <TextBlock Text="صندوق أمر واضح أسفل التيرمنال مع اقتراحات وإكمال شبحيّ. إطفاؤه يعيد الكتابة داخل الشبكة مباشرةً. يختفي تلقائياً في محرّرات كامل الشاشة."
                                                       TextWrapping="Wrap" MaxWidth="380" HorizontalAlignment="Left"
                                                       FontSize="11" Foreground="{DynamicResource Brush.TextMuted}" Margin="2,0,2,16"/>

                                            <TextBlock x:Name="FontSizeLabel" Text="حجم الخطّ" Style="{StaticResource SectionLabel}"/>
                                            <Grid FlowDirection="LeftToRight" Width="360" HorizontalAlignment="Left">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Slider x:Name="FontSizeSlider" VerticalAlignment="Center"
                                                        Style="{StaticResource AccentSlider}"
                                                        Minimum="8" Maximum="32"
                                                        IsSnapToTickEnabled="True" TickFrequency="1"
                                                        ValueChanged="FontSizeSlider_ValueChanged"/>
                                                <TextBlock x:Name="FontSizeValue" Grid.Column="1" MinWidth="30" Margin="10,0,0,0"
                                                           VerticalAlignment="Center" TextAlignment="Center"
                                                           Foreground="{DynamicResource Brush.TextMuted}"/>
                                            </Grid>

                                            <TextBlock x:Name="FontFamilyLabel" Text="نوع الخطّ" Style="{StaticResource SectionLabel}" Margin="2,18,2,8"/>
                                            <ComboBox x:Name="FontFamilyCombo" MaxWidth="360" HorizontalAlignment="Left"
                                                      MinWidth="240"
                                                      DisplayMemberPath="Display" SelectedValuePath="Value"
                                                      SelectionChanged="FontFamilyCombo_SelectionChanged"/>

                                            <!-- ===== خطوط الواجهة (عامّ) — تُحفَظ في fonts.json وتُطبَّق حيّاً ===== -->
                                            <Border Height="1" Margin="0,22,0,0" Background="{DynamicResource Brush.Border}"/>
                                            <TextBlock Text="{loc:T settings.uiFonts}" Style="{StaticResource SectionLabel}" Margin="2,16,2,4"/>
                                            <TextBlock Text="{loc:T settings.fontsHint}" TextWrapping="Wrap" MaxWidth="380" HorizontalAlignment="Left"
                                                       FontSize="11" Foreground="{DynamicResource Brush.TextMuted}" Margin="2,0,2,10"/>

                                            <TextBlock Text="{loc:T settings.uiFamily}" FontSize="11.5"
                                                       Foreground="{DynamicResource Brush.TextMuted}" Margin="2,0,2,4"/>
                                            <TextBox x:Name="FontUiFamilyBox" MaxWidth="360" MinWidth="240" HorizontalAlignment="Left"
                                                     VerticalContentAlignment="Center" Padding="8,6" FlowDirection="LeftToRight"
                                                     KeyDown="FontUiFamily_KeyDown" LostFocus="FontUiFamily_LostFocus"/>

                                            <TextBlock Text="{loc:T settings.monoFamily}" FontSize="11.5"
                                                       Foreground="{DynamicResource Brush.TextMuted}" Margin="2,12,2,4"/>
                                            <TextBox x:Name="FontMonoFamilyBox" MaxWidth="360" MinWidth="240" HorizontalAlignment="Left"
                                                     VerticalContentAlignment="Center" Padding="8,6" FlowDirection="LeftToRight"
                                                     KeyDown="FontMonoFamily_KeyDown" LostFocus="FontMonoFamily_LostFocus"/>

                                            <TextBlock Text="{loc:T settings.uiSize}" Style="{StaticResource SectionLabel}" Margin="2,16,2,6"/>
                                            <Grid FlowDirection="LeftToRight" Width="360" HorizontalAlignment="Left">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <Slider x:Name="UiSizeSlider" VerticalAlignment="Center" Style="{StaticResource AccentSlider}"
                                                        Minimum="9" Maximum="22" IsSnapToTickEnabled="True" TickFrequency="0.5"
                                                        ValueChanged="UiSizeSlider_ValueChanged"/>
                                                <TextBlock x:Name="UiSizeValue" Grid.Column="1" MinWidth="34" Margin="10,0,0,0"
                                                           VerticalAlignment="Center" TextAlignment="Center" Foreground="{DynamicResource Brush.TextMuted}"/>
                                            </Grid>

                                            <TextBlock Text="{loc:T settings.menuSize}" Style="{StaticResource SectionLabel}" Margin="2,14,2,6"/>
                                            <Grid FlowDirection="LeftToRight" Width="360" HorizontalAlignment="Left">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <Slider x:Name="MenuSizeSlider" VerticalAlignment="Center" Style="{StaticResource AccentSlider}"
                                                        Minimum="10" Maximum="22" IsSnapToTickEnabled="True" TickFrequency="0.5"
                                                        ValueChanged="MenuSizeSlider_ValueChanged"/>
                                                <TextBlock x:Name="MenuSizeValue" Grid.Column="1" MinWidth="34" Margin="10,0,0,0"
                                                           VerticalAlignment="Center" TextAlignment="Center" Foreground="{DynamicResource Brush.TextMuted}"/>
                                            </Grid>

                                            <TextBlock Text="{loc:T settings.tableSize}" Style="{StaticResource SectionLabel}" Margin="2,14,2,6"/>
                                            <Grid FlowDirection="LeftToRight" Width="360" HorizontalAlignment="Left">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <Slider x:Name="TableSizeSlider" VerticalAlignment="Center" Style="{StaticResource AccentSlider}"
                                                        Minimum="9" Maximum="20" IsSnapToTickEnabled="True" TickFrequency="0.5"
                                                        ValueChanged="TableSizeSlider_ValueChanged"/>
                                                <TextBlock x:Name="TableSizeValue" Grid.Column="1" MinWidth="34" Margin="10,0,0,0"
                                                           VerticalAlignment="Center" TextAlignment="Center" Foreground="{DynamicResource Brush.TextMuted}"/>
                                            </Grid>

                                            <!-- ===== استدارة الحواف (الكروت ونوافذ المشروع) ===== -->
                                            <TextBlock Text="{loc:T settings.cornerRadius}" Style="{StaticResource SectionLabel}" Margin="2,14,2,6"/>
                                            <Grid FlowDirection="LeftToRight" Width="360" HorizontalAlignment="Left">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <Slider x:Name="RadiusSlider" VerticalAlignment="Center" Style="{StaticResource AccentSlider}"
                                                        Minimum="0" Maximum="24" IsSnapToTickEnabled="True" TickFrequency="1"
                                                        ValueChanged="RadiusSlider_ValueChanged"/>
                                                <TextBlock x:Name="RadiusValue" Grid.Column="1" MinWidth="34" Margin="10,0,0,0"
                                                           VerticalAlignment="Center" TextAlignment="Center" Foreground="{DynamicResource Brush.TextMuted}"/>
                                            </Grid>

                                            <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                                                <Button x:Name="OpenFontJsonBtn" Content="{loc:T settings.editConfig}" Padding="14,7"
                                                        Style="{StaticResource AccentButton}" Click="OpenConfigEditor_Click"/>
                                                <Button x:Name="ApplyFontJsonBtn" Content="{loc:T settings.applyJson}" Margin="8,0,0,0" Padding="14,7"
                                                        Click="ApplyFontJson_Click"/>
                                                <Button x:Name="ResetFontBtn" Content="{loc:T settings.resetFont}" Margin="8,0,0,0" Padding="14,7" Click="ResetFont_Click"/>
                                            </StackPanel>
                                            <TextBlock x:Name="FontJsonPathText" FontSize="10.5" Margin="2,8,2,0" FlowDirection="LeftToRight"
                                                       TextTrimming="CharacterEllipsis" Foreground="{DynamicResource Brush.TextMuted}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </DockPanel>
                    </Border>
                </Border>

                <!-- ===== قائمة كل الثيمات (تُفتح من زرّ «عرض كل الثيمات») ===== -->
                <Border x:Name="ThemesOverlay" Grid.ColumnSpan="3" Background="#88000000"
                        Visibility="Collapsed" FlowDirection="LeftToRight"
                        MouseLeftButtonDown="ThemesOverlay_MouseDown">
                    <Border Width="660" MaxHeight="640" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Style="{StaticResource Card}" Padding="0" FlowDirection="RightToLeft"
                            MouseLeftButtonDown="EditorCard_MouseDown">
                        <DockPanel>
                            <Grid DockPanel.Dock="Top" Margin="22,16,14,12">
                                <TextBlock x:Name="ThemesOverlayTitle" Text="كل الثيمات" FontSize="17"
                                           FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <Button HorizontalAlignment="Right" Style="{StaticResource ChromeButton}"
                                        Content="&#xE8BB;" Click="CloseThemesOverlay_Click"/>
                            </Grid>
                            <Border DockPanel.Dock="Top" Height="1" Background="{DynamicResource Brush.Border}"/>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                          Padding="20,14,14,16">
                                <ScrollViewer.Resources>
                                    <Style TargetType="ScrollBar" BasedOn="{StaticResource ThemedScrollBar}"/>
                                </ScrollViewer.Resources>
                                <WrapPanel x:Name="ThemesOverlayPanel"/>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Border>

                <!-- ===== منتقي لون التاك (لوحة ألوان جاهزة + لون مخصّص) ===== -->
                <Popup x:Name="ColorPickerPopup" Placement="Mouse" StaysOpen="False" AllowsTransparency="True"
                       FlowDirection="RightToLeft" Closed="ColorPicker_Closed">
                    <Border Background="{DynamicResource Brush.Surface}" BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="1" CornerRadius="{DynamicResource Radius.Card}" Padding="12" Margin="6">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" BlurRadius="18" ShadowDepth="2" Opacity="0.4"/>
                        </Border.Effect>
                        <StackPanel Width="236">
                            <TextBlock x:Name="ColorPickerTitle" Text="لون المشروع" FontWeight="SemiBold"
                                       FontSize="13" Margin="0,0,0,10"/>
                            <WrapPanel x:Name="ColorSwatchPanel"/>
                            <TextBlock Text="لون مخصّص (#RRGGBB)" Style="{StaticResource SectionLabel}" Margin="2,10,2,6"/>
                            <Grid FlowDirection="LeftToRight">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="ColorHexInput" VerticalContentAlignment="Center"
                                         KeyDown="ColorHexInput_KeyDown"/>
                                <Button Grid.Column="1" Content="تطبيق" Margin="6,0,0,0" Padding="12,6"
                                        Click="ColorHexApply_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Popup>

                <!-- ===== إدارة بروفايلات الصدفات (T-101.4) ===== -->
                <Border x:Name="ProfileManagerOverlay" Grid.ColumnSpan="3" Background="#88000000"
                        Visibility="Collapsed" MouseLeftButtonDown="ProfileManagerOverlay_MouseDown">
                    <Border Width="560" MaxHeight="560" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Style="{StaticResource Card}" Padding="20"
                            MouseLeftButtonDown="EditorCard_MouseDown">
                        <DockPanel>
                            <TextBlock x:Name="ProfileManagerTitle" DockPanel.Dock="Top"
                                       Text="بروفايلات الصدفات" FontSize="16" FontWeight="SemiBold"
                                       Margin="0,0,0,14"/>

                            <TextBlock x:Name="DefaultProfileLabel" DockPanel.Dock="Top"
                                       Text="البروفايل الافتراضيّ" Style="{StaticResource SectionLabel}"/>
                            <ComboBox x:Name="DefaultProfileCombo" DockPanel.Dock="Top"
                                      DisplayMemberPath="DisplayLabel" SelectedValuePath="Id"
                                      Margin="0,0,0,14"
                                      SelectionChanged="DefaultProfileCombo_SelectionChanged"/>

                            <Grid DockPanel.Dock="Bottom" Margin="0,14,0,0">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                    <Button x:Name="ProfileAddBtn" Content="إضافة" Padding="16,8"
                                            Click="ProfileAdd_Click"/>
                                    <Button x:Name="ProfileEditBtn" Content="تعديل" Padding="16,8" Margin="8,0,0,0"
                                            Click="ProfileEdit_Click"/>
                                    <Button x:Name="ProfileDeleteBtn" Content="حذف" Padding="16,8" Margin="8,0,0,0"
                                            Click="ProfileDelete_Click"/>
                                </StackPanel>
                                <Button HorizontalAlignment="Right" Style="{StaticResource AccentButton}"
                                        x:Name="ProfileCloseBtn" Content="إغلاق" Padding="20,8"
                                        Click="ProfileManagerClose_Click"/>
                            </Grid>

                            <ListBox x:Name="ProfileList" MinHeight="200" MaxHeight="300"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="2">
                                            <TextBlock Text="{Binding DisplayLabel}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding TypeHint}" FontSize="11"
                                                       Foreground="{DynamicResource Brush.TextMuted}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>
                </Border>

                <!-- ===== محرّر بروفايل مخصّص (T-101.3) ===== -->
                <Border x:Name="ProfileEditorOverlay" Grid.ColumnSpan="3" Background="#88000000"
                        Visibility="Collapsed" MouseLeftButtonDown="ProfileEditorOverlay_MouseDown">
                    <Border Width="460" MaxHeight="600" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Style="{StaticResource Card}" Padding="20"
                            MouseLeftButtonDown="EditorCard_MouseDown">
                        <StackPanel>
                            <TextBlock x:Name="ProfileEditorTitle" Text="بروفايل مخصّص" FontSize="16"
                                       FontWeight="SemiBold" Margin="0,0,0,14"/>

                            <TextBlock Text="الاسم" Style="{StaticResource SectionLabel}"/>
                            <TextBox x:Name="ProfileEditorName"/>

                            <TextBlock Text="الملفّ التنفيذيّ (ExePath)" Style="{StaticResource SectionLabel}" Margin="2,12,2,6"/>
                            <TextBox x:Name="ProfileEditorExe" FlowDirection="LeftToRight"/>

                            <TextBlock Text="الوسائط (Arguments)" Style="{StaticResource SectionLabel}" Margin="2,12,2,6"/>
                            <TextBox x:Name="ProfileEditorArgs" FlowDirection="LeftToRight"/>

                            <TextBlock Text="مجلّد العمل" Style="{StaticResource SectionLabel}" Margin="2,12,2,6"/>
                            <TextBox x:Name="ProfileEditorWorkDir" FlowDirection="LeftToRight"/>

                            <TextBlock Text="متغيّرات البيئة (KEY=VALUE في كل سطر)"
                                       Style="{StaticResource SectionLabel}" Margin="2,12,2,6"/>
                            <TextBox x:Name="ProfileEditorEnv" MinHeight="60" AcceptsReturn="True"
                                     TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                     FlowDirection="LeftToRight"/>

                            <Grid Margin="0,20,0,0">
                                <Button HorizontalAlignment="Left" Content="إلغاء" Padding="16,8"
                                        Click="ProfileEditorCancel_Click"/>
                                <Button HorizontalAlignment="Right" Style="{StaticResource AccentButton}"
                                        Content="حفظ" Padding="20,8" Click="ProfileEditorSave_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- ===== لوحة الأوامر (Ctrl+Shift+P) ===== -->
                <Border x:Name="CommandPaletteOverlay" Grid.ColumnSpan="3" Background="#88000000"
                        Visibility="Collapsed" MouseLeftButtonDown="CommandPaletteOverlay_MouseDown">
                    <Border Width="620" MaxHeight="520" VerticalAlignment="Top" HorizontalAlignment="Center"
                            Margin="0,90,0,0" Style="{StaticResource CardStrong}" Padding="0"
                            RenderTransformOrigin="0.5,0" MouseLeftButtonDown="CommandPaletteCard_MouseDown">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="CommandPaletteTransform" Y="-24"/>
                        </Border.RenderTransform>
                        <DockPanel Margin="14">
                            <Grid DockPanel.Dock="Top">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                           VerticalAlignment="Center" Margin="4,0,10,0"
                                           Foreground="{DynamicResource Brush.TextMuted}"/>
                                <TextBox x:Name="CommandPaletteInput" Grid.Column="1"
                                         BorderThickness="0" Background="Transparent" FontSize="14"
                                         Padding="0,6"
                                         TextChanged="CommandPaletteInput_TextChanged"
                                         PreviewKeyDown="CommandPaletteInput_PreviewKeyDown"/>
                            </Grid>
                            <Border DockPanel.Dock="Top" Height="1" Margin="0,10,0,10"
                                    Background="{DynamicResource Brush.Hairline}"/>

                            <!-- رقاقات الفئات: تحصر النتائج في نوع واحد (مشاريع/أوامر/تبويبات/صدفات).
                                 تُبنى في الكود لأنّ عددها يتبع الفئات المتاحة فعليّاً. -->
                            <WrapPanel x:Name="PaletteChips" DockPanel.Dock="Top" Margin="0,0,0,4"/>

                            <TextBlock x:Name="PaletteSectionLabel" DockPanel.Dock="Top" Text="مقترَح"
                                       Style="{StaticResource Caption}" Margin="2,6,2,4"/>

                            <ListBox x:Name="CommandPaletteList" MaxHeight="330"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     MouseDoubleClick="CommandPaletteList_MouseDoubleClick">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="24"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Icon}" FontFamily="Segoe MDL2 Assets"
                                                       FontSize="13" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource Brush.Accent}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Title}" FontSize="13"
                                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Hint}" FontSize="11"
                                                       VerticalAlignment="Center" Margin="10,0,0,0"
                                                       Foreground="{DynamicResource Brush.TextMuted}"
                                                       FlowDirection="LeftToRight"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
