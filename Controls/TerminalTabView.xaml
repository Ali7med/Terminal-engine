<UserControl x:Class="TerminalLauncher.Controls.TerminalTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:TerminalLauncher.Controls"
             FlowDirection="RightToLeft">
    <UserControl.Resources>
        <!-- زرّ تمرير شفّاف (بلا كروم افتراضيّ) — لمنطقة الصفحة فقط -->
        <Style x:Key="TransparentRepeat" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- شريط تمرير نحيل متوافق مع الثيم (مقبض دائريّ، بلا أسهم، مسار شفّاف) -->
        <Style x:Key="SlimScroll" TargetType="ScrollBar">
            <Setter Property="Width" Value="9"/>
            <Setter Property="MinWidth" Value="9"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource TransparentRepeat}" Command="ScrollBar.PageUpCommand"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource TransparentRepeat}" Command="ScrollBar.PageDownCommand"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="Th" CornerRadius="4" Margin="2,0"
                                                        Background="{DynamicResource Brush.Border}"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Th" Property="Background"
                                                                Value="{DynamicResource Brush.Accent}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <!-- سطح واحد موحّد بخلفية التيرمنال (تُصبح شفّافة عند تفعيل صورة خلفيّة لتظهر خلف التيرمنال) -->
    <Grid x:Name="RootGrid" Background="{DynamicResource Brush.TerminalBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- شريط علوي مدمج: طبقة تعتيم شبه شفّافة حسب الثيم (Brush.HeaderScrim) كي يبقى نصّ الشريط
             مقروءاً فوق صورة الخلفيّة — داكنة/كتابة فاتحة في الوضع الداكن، فاتحة/كتابة داكنة في الفاتح -->
        <Border Grid.Row="0" Padding="8,5" Background="{DynamicResource Brush.HeaderScrim}"
                BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ComboBox x:Name="ShellCombo" Width="160"
                              DisplayMemberPath="Display"
                              SelectionChanged="ShellCombo_SelectionChanged"
                              DropDownOpened="ShellCombo_DropDownOpened"
                              DropDownClosed="ShellCombo_DropDownClosed"
                              ToolTip="الصدفة الافتراضية لهذا الأمر (يُحفظ التغيير)"/>
                    <TextBlock x:Name="StatusText" Foreground="{DynamicResource Brush.TextMuted}"
                               VerticalAlignment="Center" Margin="12,0" FontSize="12"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <!-- سجلّ الأوامر (T-106): زرّ يفتح Popup بقائمة الأوامر الأخيرة -->
                    <Button x:Name="HistoryButton" Style="{StaticResource IconButton}" Content="🕘"
                            Click="HistoryButton_Click"/>
                    <Popup x:Name="HistoryPopup" PlacementTarget="{Binding ElementName=HistoryButton}"
                           Placement="Bottom" StaysOpen="False" AllowsTransparency="True"
                           FlowDirection="{Binding FlowDirection, RelativeSource={RelativeSource AncestorType=UserControl}}">
                        <Border Background="{DynamicResource Brush.Surface}"
                                BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1"
                                CornerRadius="9" Padding="4" Margin="6" MinWidth="320" MaxWidth="520">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="14" ShadowDepth="2" Opacity="0.35" Color="#000000"/>
                            </Border.Effect>
                            <DockPanel>
                                <!-- بحث سريع: يصفّي أثناء الكتابة؛ الأسهم تتنقّل والقائمة، Enter يلصق وينفّذ -->
                                <Border DockPanel.Dock="Top" Margin="2,2,2,4" Padding="8,5" CornerRadius="6"
                                        Background="{DynamicResource Brush.Bg}"
                                        BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1">
                                    <TextBox x:Name="HistorySearch" BorderThickness="0" Background="Transparent"
                                             Foreground="{DynamicResource Brush.Text}" VerticalContentAlignment="Center"
                                             FontFamily="Cascadia Mono, Consolas"
                                             TextChanged="HistorySearch_TextChanged"
                                             PreviewKeyDown="HistorySearch_PreviewKeyDown"/>
                                </Border>
                                <ListBox x:Name="HistoryList" MaxHeight="320" BorderThickness="0"
                                         Background="Transparent" Foreground="{DynamicResource Brush.Text}"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         MouseDoubleClick="HistoryList_MouseDoubleClick"
                                         PreviewKeyDown="HistoryList_PreviewKeyDown">
                                    <ListBox.Resources>
                                        <Style TargetType="ScrollBar" BasedOn="{StaticResource SlimScroll}"/>
                                    </ListBox.Resources>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="8,5"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis"
                                                       FontFamily="Cascadia Mono, Consolas"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>
                        </Border>
                    </Popup>
                    <Button Style="{StaticResource IconButton}" Content="↻" Click="RestartButton_Click"
                            ToolTip="إعادة التشغيل"/>
                    <Button Style="{StaticResource IconButton}" Content="■" Click="StopButton_Click"
                            ToolTip="إيقاف"/>
                    <Button Style="{StaticResource IconButton}" Content="🧹" Click="ClearButton_Click"
                            ToolTip="تنظيف الشاشة"/>
                    <!-- فصل: نقرة → نافذة مستقلّة · Shift+نقرة → تيرمنال خارجيّ بنفس المسار (E8A7 = OpenInNewWindow) -->
                    <Button x:Name="DetachButton" Style="{StaticResource IconButton}"
                            Content="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                            Click="DetachButton_Click"
                            ToolTip="فتح في نافذة مستقلّة · Shift: تيرمنال خارجيّ بنفس المسار"/>
                    <ToggleButton x:Name="ExpandToggle" Style="{StaticResource IconToggle}"
                                  Content="&#xE740;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                  Click="ExpandToggle_Click" ToolTip="توسيع مساحة العمل"/>
                    <Button Style="{StaticResource IconButton}" Content="✕" Click="CloseButton_Click"
                            ToolTip="إغلاق هذا الجزء (Ctrl+W)"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- تقسيم أفقيّ: عمود التيرمنال + فاصل قابل للسحب + عمود محرّر الملفّ (مطويّ افتراضياً — T-7).
             العمودان يتشاركان الصفّ؛ يبدأ عمود المحرّر بعرض 0 وإخفاء، ويُظهَر بنصف العرض عند فتح ملفّ. -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="TerminalColumn" Width="*"/>
                <ColumnDefinition x:Name="SplitterColumn" Width="Auto"/>
                <ColumnDefinition x:Name="EditorColumn" Width="0"/>
            </Grid.ColumnDefinitions>

            <!-- محاكي الكونسول: عارض شبكة خلايا SkiaSharp (SGR/ألوان/كتل/روابط تُرسَم داخلياً).
                 للقراءة فقط بمنطق كونسول: PreviewTextInput/التحديد/النسخ/التمرير كلّها على العارض.
                 العارض يستقبل تركيز لوحة المفاتيح (Focusable) ويرسم LTR مهما كان اتّجاه الواجهة. -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <!-- صندوق التأليف: ارتفاع تلقائيّ، مطويّ حتى يُفعَّل ويكون على الشاشة الأساس -->
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <!-- العارض يملأ العرض كاملاً (كعرض الرأس). شريط التمرير يطفو داخليّاً على الحافّة
                         اليمنى (LTR) بلا اقتطاع عرض — يظهر فقط عند الحاجة، فوق آخر عمود (هامش عادةً). -->
                    <ctrl:SkiaTerminalRenderer x:Name="Renderer"
                                               Margin="0"
                                               Focusable="True" ClipToBounds="True"
                                               FlowDirection="LeftToRight"
                                               PreviewKeyDown="Renderer_PreviewKeyDown"
                                               PreviewTextInput="Renderer_PreviewTextInput"
                                               PreviewMouseLeftButtonDown="Renderer_MouseLeftDown"
                                               PreviewMouseMove="Renderer_MouseMove"
                                               PreviewMouseLeftButtonUp="Renderer_MouseLeftUp"
                                               PreviewMouseRightButtonUp="Renderer_MouseRightUp"
                                               PreviewMouseWheel="Renderer_MouseWheel"/>
                    <ScrollBar x:Name="Scroll" Orientation="Vertical" Style="{StaticResource SlimScroll}"
                               HorizontalAlignment="Left" Margin="0,2"
                               Scroll="Scroll_Scroll"/>

                    <!-- شريط البحث في المخرجات (Ctrl+F) — يظهر أعلى الزاوية فوق التيرمنال، LTR داخلياً -->
                    <Border x:Name="SearchBar" Visibility="Collapsed"
                            VerticalAlignment="Top" HorizontalAlignment="Right" Margin="10"
                            FlowDirection="LeftToRight"
                            Background="{DynamicResource Brush.Surface}"
                            BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1"
                            CornerRadius="9" Padding="6,4">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBox x:Name="SearchInput" Width="180" Height="26"
                                     BorderThickness="0" Background="Transparent" Padding="6,2"
                                     VerticalContentAlignment="Center"
                                     TextChanged="SearchInput_TextChanged"
                                     PreviewKeyDown="SearchInput_PreviewKeyDown"/>
                            <TextBlock x:Name="SearchCount" MinWidth="54" Margin="6,0" FontSize="11"
                                       VerticalAlignment="Center" TextAlignment="Center"
                                       Foreground="{DynamicResource Brush.TextMuted}"/>
                            <Button Style="{StaticResource IconButton}" Content="‹" FontSize="16"
                                    Click="SearchPrev_Click" ToolTip="السابق (Shift+Enter)"/>
                            <Button Style="{StaticResource IconButton}" Content="›" FontSize="16"
                                    Click="SearchNext_Click" ToolTip="التالي (Enter)"/>
                            <Button Style="{StaticResource IconButton}" Content="✕"
                                    Click="SearchClose_Click" ToolTip="إغلاق (Esc)"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ===== صندوق التأليف الغنيّ (نمط Warp) =====
                     صندوق إدخال منفصل واضح: يُكتب فيه الأمر، تظهر قائمة اقتراحات فوقه (تاريخ + أوامر
                     شائعة + ملفات المجلد)، والإكمال الشبحيّ inline يُقبَل بـ Tab. يُرسَل عند Enter.
                     يظهر على الشاشة الأساس فقط ويختفي في الشاشة البديلة (vim/less). LTR داخليّاً. -->
                <!-- الإنبت والتيرمنال قطعة واحدة: خلفيّة شفّافة (تظهر خلفهما الصورة نفسها) ويفصلهما
                     خطّ شعرة رفيع فقط لا بنل صلبة — كتصميم Warp. -->
                <Border x:Name="ComposerBar" Grid.Row="1" Visibility="Collapsed"
                        FlowDirection="LeftToRight" Margin="0"
                        Background="Transparent"
                        BorderBrush="{DynamicResource Brush.Hairline}" BorderThickness="0,1,0,0">
                    <DockPanel>
                        <!-- قائمة الاقتراحات: منسدلة تطفو فوق سطر الإدخال — لها سطح خفيف للقراءة.
                             تستعمل ستايل ListBox المُثيَّم (تمرير خافت + نشِط بلكنة) — لا override محلّيّ. -->
                        <Border x:Name="SuggestBox" DockPanel.Dock="Top" Visibility="Collapsed"
                                Margin="10,8,10,0" Padding="4,4,4,0" CornerRadius="10,10,0,0"
                                Background="{DynamicResource Brush.Glass}"
                                BorderBrush="{DynamicResource Brush.Hairline}" BorderThickness="0,0,0,1">
                            <ListBox x:Name="SuggestList" MaxHeight="240" BorderThickness="0"
                                     Background="Transparent" Padding="0,0,0,6"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     PreviewMouseLeftButtonUp="SuggestList_Click">
                                <ListBox.Resources>
                                    <Style TargetType="ScrollBar" BasedOn="{StaticResource SlimScroll}"/>
                                </ListBox.Resources>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="18"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="11"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource Brush.TextMuted}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Text}"
                                                       FontFamily="Cascadia Mono, Consolas" FontSize="12.5"
                                                       Foreground="{DynamicResource Brush.Text}"
                                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                            <Border Grid.Column="2" CornerRadius="4" Padding="6,1" Margin="9,0,0,0"
                                                    VerticalAlignment="Center"
                                                    Background="{DynamicResource Brush.KeyCap}">
                                                <TextBlock Text="{Binding Kind}" FontSize="9.5"
                                                           Foreground="{DynamicResource Brush.TextMuted}"/>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>

                        <!-- سطر الإدخال: باث المجلد (مكتوم) + رمز الموجّه + الحقل + تلميح -->
                        <Grid Margin="14,10,14,11">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <!-- الباث الحاليّ (مجلد العمل) — يُستخرَج من الموجّه؛ يعرف المستخدم أين يقف -->
                            <TextBlock Grid.Column="0" x:Name="ComposerCwd" VerticalAlignment="Center"
                                       Margin="0,0,8,0" FontFamily="Cascadia Mono, Consolas" FontSize="12"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       TextTrimming="CharacterEllipsis" MaxWidth="260"/>
                            <TextBlock Grid.Column="1" Text="❯" VerticalAlignment="Center"
                                       Margin="0,0,10,0" FontFamily="Cascadia Mono, Consolas"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="{DynamicResource Brush.Accent}"/>
                            <!-- طبقة الشبح: ذيل الإكمال (لون أفتح مكتوم) + حبّة tab — تُوضَع أفقيّاً عند
                                 نهاية النصّ المكتوب عبر GetRectFromCharacterIndex فتتحاذى تماماً. -->
                            <Canvas Grid.Column="2" IsHitTestVisible="False" ClipToBounds="True">
                                <!-- مؤشّر مخصّص واضح (شريط باللكنة) — أوضح من مؤشّر النظام الرفيع.
                                     يُوضَع عند موضع الكتابة عبر GetRectFromCharacterIndex ويومض. -->
                                <Border x:Name="ComposerCaret" Width="2.5" Height="18" CornerRadius="1"
                                        Background="{DynamicResource Brush.Accent}" Visibility="Collapsed"/>
                                <StackPanel x:Name="ComposerGhostPanel" Orientation="Horizontal"
                                            Canvas.Top="0" Visibility="Collapsed">
                                    <TextBlock x:Name="ComposerGhost"
                                               FontFamily="Cascadia Mono, Consolas" FontSize="13.5"
                                               Foreground="{DynamicResource Brush.TextMuted}" Opacity="0.5"/>
                                    <Border x:Name="ComposerTabChip" Margin="8,0,0,0" Padding="6,0"
                                            Height="17" VerticalAlignment="Center" CornerRadius="4"
                                            Background="{DynamicResource Brush.KeyCap}">
                                        <TextBlock Text="tab" FontFamily="Cascadia Mono, Consolas"
                                                   FontSize="10.5" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource Brush.TextMuted}"/>
                                    </Border>
                                </StackPanel>
                            </Canvas>
                            <TextBox Grid.Column="2" x:Name="ComposerInput"
                                     Background="Transparent" BorderThickness="0" Padding="0"
                                     Foreground="{DynamicResource Brush.Text}"
                                     CaretBrush="Transparent"
                                     FontFamily="Cascadia Mono, Consolas" FontSize="13.5"
                                     AcceptsReturn="True" AcceptsTab="False" MaxLength="0"
                                     TextWrapping="Wrap" MaxLines="8"
                                     VerticalScrollBarVisibility="Auto"
                                     TextChanged="Composer_TextChanged"
                                     SelectionChanged="Composer_SelectionChanged"
                                     LostKeyboardFocus="Composer_LostFocus"
                                     GotKeyboardFocus="Composer_GotFocus"
                                     PreviewKeyDown="Composer_PreviewKeyDown"/>
                            <TextBlock Grid.Column="3" x:Name="ComposerHint" Text="↵"
                                       VerticalAlignment="Center" Margin="10,0,0,0"
                                       FontSize="11" Opacity="0.4"
                                       Foreground="{DynamicResource Brush.TextMuted}"/>
                        </Grid>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- الفاصل القابل للسحب — ظاهر فقط حين يكون المحرّر مفتوحاً -->
            <GridSplitter x:Name="EditorSplitter" Grid.Column="1" Width="4"
                          Visibility="Collapsed"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="{DynamicResource Brush.Border}"
                          FlowDirection="LeftToRight"/>

            <!-- لوحة تحرير الملفّ داخل التاب (T-7) — مطويّة حتى فتح ملفّ -->
            <ctrl:FileEditorPanel x:Name="EditorPanel" Grid.Column="2"
                                  Visibility="Collapsed"/>
        </Grid>
    </Grid>
</UserControl>
