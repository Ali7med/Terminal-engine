<UserControl x:Class="TerminalLauncher.Controls.AiPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource Brush.Surface}"
             TextOptions.TextFormattingMode="Display">

    <!-- الأرقام لاتينيّة دائماً حتى في العربيّة؛ الاتّجاه يُضبط حيّاً من Loc.Flow في الكود. -->
    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="NumberSubstitution.Substitution" Value="European"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- الترويسة: العنوان + وسم المزوّد/النموذج + أفعال المحادثة -->
        <Border Grid.Row="0" Background="{DynamicResource Brush.Surface2}"
                BorderBrush="{DynamicResource Brush.Hairline}" BorderThickness="0,0,0,1" Padding="10,7">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Name="TitleText" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock x:Name="OriginText" FontSize="10"
                               Foreground="{DynamicResource Brush.TextMuted}"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="CopyAllBtn" Style="{StaticResource IconButton}"
                            Content="⧉" Click="CopyAll_Click"/>
                    <Button x:Name="ClearBtn" Style="{StaticResource IconButton}"
                            Content="✚" Click="Clear_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- المحادثة -->
        <ScrollViewer Grid.Row="1" x:Name="Scroller" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled" Padding="10,8">
            <StackPanel x:Name="MessageHost"/>
        </ScrollViewer>

        <!-- شريط الخطأ: رسالة بشريّة + زرّ إجراء واحد -->
        <Border Grid.Row="2" x:Name="ErrorBar" Visibility="Collapsed" Margin="8,0,8,8"
                Background="{DynamicResource Brush.Surface2}"
                BorderBrush="{DynamicResource Brush.Danger}" BorderThickness="1"
                CornerRadius="6" Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="ErrorText" TextWrapping="Wrap" FontSize="12"/>
                    <TextBlock x:Name="ErrorOrigin" FontSize="10" Margin="0,3,0,0"
                               Foreground="{DynamicResource Brush.TextMuted}"/>
                </StackPanel>
                <Button Grid.Column="1" x:Name="ErrorActionBtn" Style="{StaticResource AccentButton}"
                        VerticalAlignment="Center" Margin="8,0,0,0" Click="ErrorAction_Click"/>
            </Grid>
        </Border>

        <!-- الإدخال -->
        <Border Grid.Row="3" Background="{DynamicResource Brush.Surface2}"
                BorderBrush="{DynamicResource Brush.Hairline}" BorderThickness="0,1,0,0" Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0" x:Name="InputBox" Style="{StaticResource SearchPill}"
                         AcceptsReturn="True" TextWrapping="Wrap" MaxHeight="120"
                         VerticalScrollBarVisibility="Auto"
                         PreviewKeyDown="Input_PreviewKeyDown"/>

                <Button Grid.Column="1" x:Name="SendBtn" Style="{StaticResource AccentButton}"
                        Margin="6,0,0,0" MinWidth="64" Click="Send_Click"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
