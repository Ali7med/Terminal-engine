<UserControl x:Class="TerminalLauncher.Controls.FileEditorPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
             FlowDirection="LeftToRight">
    <Grid Background="{DynamicResource Brush.TerminalBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- شريط عنوان اللوحة: اسم الملفّ + نقطة تعديل + زرّ إغلاق -->
        <Border Grid.Row="0" Padding="8,5"
                Background="{DynamicResource Brush.Surface}"
                BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="DirtyDot" Grid.Column="0" Text="&#x25CF;" FontSize="13"
                           VerticalAlignment="Center" Margin="0,0,6,0"
                           Visibility="Collapsed"
                           Foreground="{DynamicResource Brush.Accent}"/>
                <TextBlock x:Name="FileNameText" Grid.Column="1"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                           FontFamily="Cascadia Mono, Consolas" FontSize="12"
                           Foreground="{DynamicResource Brush.Text}"/>
                <Button Grid.Column="2" Style="{StaticResource IconButton}" Content="✕"
                        Click="CloseButton_Click" ToolTip="{Binding CloseTip, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            </Grid>
        </Border>

        <!-- المحرّر (AvalonEdit) — خطّ أحاديّ، أرقام أسطر، ثيم داكن -->
        <avalon:TextEditor x:Name="Editor" Grid.Row="1"
                           FontFamily="Cascadia Mono, Consolas" FontSize="13"
                           ShowLineNumbers="True"
                           WordWrap="False"
                           HorizontalScrollBarVisibility="Auto"
                           VerticalScrollBarVisibility="Auto"
                           Background="{DynamicResource Brush.TerminalBg}"
                           Foreground="{DynamicResource Brush.Text}"
                           Padding="4,2"/>
    </Grid>
</UserControl>
