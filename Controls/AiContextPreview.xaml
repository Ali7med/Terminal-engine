<UserControl x:Class="TerminalLauncher.Controls.AiContextPreview"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="NumberSubstitution.Substitution" Value="European"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
        </Style>
    </UserControl.Resources>

    <!-- لوحة مضمّنة خفيفة لا نافذة كاملة: المعاينة القسريّة تتكرّر، ونافذة modal كلّ مرّة
         تُحوّل حارس خصوصيّة إلى ضريبة نقر يتعلّم المستخدم تجاوزها بلا قراءة. -->
    <Border Background="{DynamicResource Brush.Surface2}"
            BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1"
            CornerRadius="8" Padding="10,8" Margin="0,4,0,8">
        <StackPanel>
            <TextBlock x:Name="HeadlineText" FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap"/>

            <!-- ما حُجب: مقنَّعاً، مع «ليس سرّاً» لكلّ عنصر -->
            <ItemsControl x:Name="RedactedList" Margin="0,8,0,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Kind}" FontSize="11"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource Brush.TextMuted}"/>
                            <TextBlock Grid.Column="1" Text="{Binding Masked}" FontSize="11"
                                       Margin="8,0,8,0" VerticalAlignment="Center"
                                       FlowDirection="LeftToRight"
                                       FontFamily="Cascadia Mono, Consolas"
                                       TextTrimming="CharacterEllipsis"/>
                            <Button Grid.Column="2" Content="{Binding AllowLabel}" FontSize="10"
                                    Padding="6,2" Tag="{Binding Token}"
                                    Click="AllowToken_Click"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- ما سيُرسَل حرفياً، قابل للتحرير -->
            <TextBox x:Name="PayloadBox" Margin="0,8,0,0" MaxHeight="180"
                     AcceptsReturn="True" TextWrapping="NoWrap"
                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                     FlowDirection="LeftToRight"
                     FontFamily="Cascadia Mono, Consolas" FontSize="11"
                     Background="{DynamicResource Brush.Surface}"
                     Foreground="{DynamicResource Brush.Text}"
                     BorderBrush="{DynamicResource Brush.Hairline}" BorderThickness="1"/>

            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <Button x:Name="ConfirmBtn" Style="{StaticResource AccentButton}"
                        Padding="12,5" Click="Confirm_Click" IsDefault="True"/>
                <Button x:Name="CancelBtn" Margin="8,0,0,0" Padding="12,5"
                        Click="Cancel_Click" IsCancel="True"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
