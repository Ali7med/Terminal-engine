<Window x:Class="TerminalLauncher.Views.ServerMonitorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:local="clr-namespace:TerminalLauncher.Views"
        Title="مراقب الخوادم" Height="680" Width="1080"
        Icon="pack://application:,,,/Assets/AppIcon/app.ico"
        MinHeight="480" MinWidth="820"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" Background="{DynamicResource Brush.Bg}"
        TextOptions.TextFormattingMode="Ideal"
        FontFamily="{DynamicResource Font.Ui}" FontSize="13"
        NumberSubstitution.Substitution="European"
        Foreground="{DynamicResource Brush.Text}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="46" ResizeBorderThickness="8"
                            CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- تبويب حقيقيّ بشكل خطّ سفليّ (underline tab) لشريط الأقراص/المجلّدات/الملفّات -->
        <Style x:Key="ServerModeTab" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}"/>
            <Setter Property="Margin" Value="0,0,2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="Transparent" Padding="16,9">
                            <StackPanel>
                                <TextBlock Text="{TemplateBinding Content}" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{TemplateBinding Foreground}" HorizontalAlignment="Center"/>
                                <Border x:Name="ul" Height="2.5" Margin="0,7,0,0" CornerRadius="2" Background="Transparent"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource Brush.Accent}"/>
                                <Setter TargetName="ul" Property="Background" Value="{DynamicResource Brush.Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- قالب عقدة المجلّد — مشترك بين شجرة المجلّدات وشجرة لوحة القيادة.
             عقدة التحميل (IsLoadingNode) تُعرَض شريطَ تقدّم inline بدل صفّ المجلّد. -->
        <HierarchicalDataTemplate DataType="{x:Type local:FolderNode}" ItemsSource="{Binding Children}">
            <Grid MinWidth="200">
                <ProgressBar x:Name="loadBar" Height="4" Width="120" HorizontalAlignment="Left"
                             Margin="2,4" IsIndeterminate="True" Visibility="Collapsed"
                             Foreground="{DynamicResource Brush.Accent}"
                             Background="{DynamicResource Brush.Surface2}" BorderThickness="0"/>
                <Grid x:Name="rowGrid">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets"
                                   VerticalAlignment="Center" Margin="0,0,8,0"
                                   Foreground="{DynamicResource Brush.Accent}"/>
                        <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"
                                   Foreground="{DynamicResource Brush.Text}"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="{Binding SizeText}" Margin="16,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource Brush.TextMuted}"/>
                </Grid>
            </Grid>
            <HierarchicalDataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsLoadingNode}" Value="True">
                    <Setter TargetName="loadBar" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="rowGrid" Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </HierarchicalDataTemplate.Triggers>
        </HierarchicalDataTemplate>

        <!-- تحميل كسول موثوق: EventSetter يمرّر TreeViewItem نفسه (sender) لأيّ عمق -->
        <Style x:Key="TreeItemStyle" TargetType="TreeViewItem">
            <EventSetter Event="Expanded" Handler="TreeItem_Expanded"/>
        </Style>

        <!-- أنماط جداول موحّدة (تُستعمل في تبويب الإدارة) -->
        <Style x:Key="GridColHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="GridCell" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder" Background="{DynamicResource Brush.Bg}" CornerRadius="6" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="46"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ===== شريط العنوان ===== -->
            <Grid Grid.Row="0" Margin="14,0,8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Border Width="26" Height="26" CornerRadius="7" Background="{DynamicResource Brush.Accent}">
                        <TextBlock Text="&#xE968;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource Brush.OnAccent}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="TitleText" Text="مراقب الخوادم" FontWeight="SemiBold" FontSize="13.5"
                               VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="MinButton" Style="{StaticResource ChromeButton}"
                            Content="&#xE921;" Click="MinButton_Click"/>
                    <Button x:Name="MaxButton" Style="{StaticResource ChromeButton}"
                            Content="&#xE922;" Click="MaxButton_Click"/>
                    <Button x:Name="CloseButton" Style="{StaticResource ChromeCloseButton}"
                            Content="&#xE8BB;" Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>

            <!-- ===== المحتوى ===== -->
            <Grid Grid.Row="1" Margin="14,4,14,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="56"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- الشريط المطويّ للخوادم: أيقونة + إضافة + دوائر الخوادم؛ يفتح لوحةً كاملة بالمرور -->
                <Border x:Name="ServerRail" Grid.Column="0" Style="{StaticResource Card}" Padding="0"
                        MouseEnter="ServerRail_MouseEnter">
                    <DockPanel Margin="0,8">
                        <Button x:Name="RailMenuBtn" DockPanel.Dock="Top" Style="{StaticResource IconButton}"
                                Content="&#xE700;" FontFamily="Segoe MDL2 Assets" FontSize="16" Height="38"
                                Foreground="{DynamicResource Brush.Text}" Click="RailMenu_Click" ToolTip="الخوادم"/>
                        <Button x:Name="RailAddBtn" DockPanel.Dock="Top" Style="{StaticResource IconButton}"
                                Content="＋" FontSize="20" Height="38"
                                Foreground="{DynamicResource Brush.Accent}" Click="AddBtn_Click" ToolTip="إضافة خادم"/>
                        <Border DockPanel.Dock="Top" Height="1" Margin="12,6" Background="{DynamicResource Brush.Border}"/>
                        <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="ServerDots">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Margin="0,4" Width="36" Height="36" Cursor="Hand"
                                                Tag="{Binding}" Click="RailDot_Click" ToolTip="{Binding Name}"
                                                HorizontalAlignment="Center">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="d" Width="32" Height="32" CornerRadius="16"
                                                            Background="{Binding EffectiveColor}"
                                                            BorderBrush="Transparent" BorderThickness="2">
                                                        <TextBlock Text="{Binding Initial}" HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center" FontWeight="Bold"
                                                                   Foreground="White" FontSize="13"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="d" Property="BorderBrush"
                                                                    Value="{DynamicResource Brush.Text}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!-- اللوحة الرئيسة -->
                <Border Grid.Column="2" Style="{StaticResource Card}" Padding="0">
                    <DockPanel>
                        <!-- شريط الحالة (مُعاد تصميمه: شارة حالة + مضيف + أزرار مأيقنة) -->
                        <Border DockPanel.Dock="Top" Padding="14,11" Background="{DynamicResource Brush.Surface}"
                                BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- شارة الحالة (نقطة + نصّ داخل حبّة) -->
                                <Border Grid.Column="0" CornerRadius="13" Padding="11,5" VerticalAlignment="Center"
                                        Background="{DynamicResource Brush.Bg}"
                                        BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1">
                                    <StackPanel Orientation="Horizontal">
                                        <Border x:Name="StatusDot" Width="9" Height="9" CornerRadius="5"
                                                VerticalAlignment="Center" Margin="0,0,7,0"
                                                Background="{DynamicResource Brush.TextMuted}"/>
                                        <TextBlock x:Name="StatusText" Text="غير متّصل" FontWeight="SemiBold" FontSize="12"/>
                                    </StackPanel>
                                </Border>

                                <!-- المضيف (سطر ثانويّ، يُقصّ إن طال) -->
                                <TextBlock x:Name="StatusSub" Grid.Column="1" VerticalAlignment="Center"
                                           Margin="12,0,12,0" FontSize="11.5" FlowDirection="LeftToRight"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource Brush.TextMuted}"/>

                                <StackPanel Grid.Column="2" Orientation="Horizontal">
                                    <Button x:Name="RefreshBtn" Padding="12,7" Margin="0,0,8,0"
                                            Click="RefreshBtn_Click" IsEnabled="False">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock x:Name="RefreshBtnText" Text="تحديث"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="DisconnectBtn" Padding="12,7"
                                            Click="DisconnectBtn_Click" IsEnabled="False">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE8CB;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock x:Name="DisconnectBtnText" Text="قطع الاتّصال"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- شريط تبويبات العرض + التحكّم بحجم خطّ التفاصيل (يظهر عند الاتّصال) -->
                        <Border x:Name="ModeBar" DockPanel.Dock="Top" Visibility="Collapsed"
                                Padding="12,2,12,0" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton x:Name="ModeDashboard" GroupName="SrvMode" IsChecked="True"
                                                 Style="{StaticResource ServerModeTab}" Content="لوحة القيادة" Checked="Mode_Checked"/>
                                    <RadioButton x:Name="ModeDisks" GroupName="SrvMode"
                                                 Style="{StaticResource ServerModeTab}" Content="الأقراص" Checked="Mode_Checked"/>
                                    <RadioButton x:Name="ModeFolders" GroupName="SrvMode"
                                                 Style="{StaticResource ServerModeTab}" Content="المجلّدات" Checked="Mode_Checked"/>
                                    <RadioButton x:Name="ModeFiles" GroupName="SrvMode"
                                                 Style="{StaticResource ServerModeTab}" Content="الملفّات" Checked="Mode_Checked"/>
                                    <RadioButton x:Name="ModeMgmt" GroupName="SrvMode"
                                                 Style="{StaticResource ServerModeTab}" Content="الإدارة" Checked="Mode_Checked"/>
                                    <RadioButton x:Name="ModeContainers" GroupName="SrvMode"
                                                 Style="{StaticResource ServerModeTab}" Content="الحاويات" Checked="Mode_Checked"/>
                                </StackPanel>

                                <!-- حجم خطّ التفاصيل (موحّد للشجرة والتفاصيل والجدول) -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                                            FlowDirection="LeftToRight">
                                    <TextBlock Text="&#xE8E9;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                               VerticalAlignment="Center" Margin="0,0,6,0"
                                               Foreground="{DynamicResource Brush.TextMuted}" ToolTip="حجم خطّ التفاصيل"/>
                                    <Button x:Name="FontMinusBtn" Content="A−" Padding="8,3" MinWidth="30"
                                            Click="FontMinus_Click" ToolTip="تصغير الخطّ"/>
                                    <TextBlock x:Name="FontSizeLabel" MinWidth="26" TextAlignment="Center"
                                               VerticalAlignment="Center" Margin="4,0"/>
                                    <Button x:Name="FontPlusBtn" Content="A+" Padding="8,3" MinWidth="30"
                                            Click="FontPlus_Click" ToolTip="تكبير الخطّ"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- منطقة المحتوى (لوحات متراكبة تتبدّل بالرؤية) -->
                        <Grid>
                            <!-- تلميح الفراغ -->
                            <Border x:Name="EmptyHint" Background="Transparent">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE968;" FontFamily="Segoe MDL2 Assets" FontSize="40"
                                               Foreground="{DynamicResource Brush.TextMuted}" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="EmptyHintText" Text="اختر خادماً واضغط «اتّصال»"
                                               Foreground="{DynamicResource Brush.TextMuted}" Margin="0,12,0,0"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- ===== لوحة القيادة (الافتراضيّة عند الاتّصال) ===== -->
                            <ScrollViewer x:Name="DashboardScroller" Visibility="Collapsed"
                                          VerticalScrollBarVisibility="Auto" Padding="16">
                                <ScrollViewer.Resources>
                                    <Style TargetType="ScrollBar" BasedOn="{StaticResource ThemedScrollBar}"/>
                                </ScrollViewer.Resources>
                                <StackPanel>
                                    <!-- شريط المراقبة الحيّة -->
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="LiveUpdated" VerticalAlignment="Center" FontSize="11"
                                                   Foreground="{DynamicResource Brush.TextMuted}" FlowDirection="LeftToRight"/>
                                        <ToggleButton x:Name="LiveToggle" Grid.Column="1" Content="● مباشر" MinWidth="90"
                                                      Style="{StaticResource SegToggle}"
                                                      Checked="LiveToggle_Changed" Unchecked="LiveToggle_Changed"/>
                                    </Grid>

                                    <!-- بطاقات إحصائيّة سريعة -->
                                    <UniformGrid Rows="1" Columns="4">
                                        <Border Margin="0,0,6,0" Padding="14,12" CornerRadius="12"
                                                Background="{DynamicResource Brush.Surface}"
                                                BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1">
                                            <StackPanel>
                                                <TextBlock x:Name="TileUptimeCap" Text="⏱ التشغيل" FontSize="11" Foreground="{DynamicResource Brush.TextMuted}"/>
                                                <TextBlock x:Name="TileUptime" Text="—" FontSize="17" FontWeight="Bold" Margin="0,4,0,0"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Margin="3,0" Padding="14,12" CornerRadius="12"
                                                Background="{DynamicResource Brush.Surface}"
                                                BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1">
                                            <StackPanel>
                                                <TextBlock x:Name="TileLoadCap" Text="⚙ الحِمل (1د)" FontSize="11" Foreground="{DynamicResource Brush.TextMuted}"/>
                                                <TextBlock x:Name="TileLoad" Text="—" FontSize="20" FontWeight="Bold" Margin="0,4,0,0"
                                                           FlowDirection="LeftToRight"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Margin="3,0" Padding="14,12" CornerRadius="12"
                                                Background="{DynamicResource Brush.Surface}"
                                                BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1">
                                            <StackPanel>
                                                <TextBlock x:Name="TileRamCap" Text="🧠 الذاكرة" FontSize="11" Foreground="{DynamicResource Brush.TextMuted}"/>
                                                <TextBlock x:Name="TileRam" Text="—" FontSize="17" FontWeight="Bold" Margin="0,4,0,4"
                                                           FlowDirection="LeftToRight"/>
                                                <ProgressBar x:Name="TileRamBar" Height="6" Minimum="0" Maximum="100"
                                                             Foreground="{DynamicResource Brush.Accent}"
                                                             Background="{DynamicResource Brush.Bg}" BorderThickness="0"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Margin="6,0,0,0" Padding="14,12" CornerRadius="12"
                                                Background="{DynamicResource Brush.Surface}"
                                                BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1">
                                            <StackPanel>
                                                <TextBlock x:Name="TileRootCap" Text="💽 القرص /" FontSize="11" Foreground="{DynamicResource Brush.TextMuted}"/>
                                                <TextBlock x:Name="TileRoot" Text="—" FontSize="17" FontWeight="Bold" Margin="0,4,0,4"
                                                           FlowDirection="LeftToRight"/>
                                                <ProgressBar x:Name="TileRootBar" Height="6" Minimum="0" Maximum="100"
                                                             Foreground="{DynamicResource Brush.Accent}"
                                                             Background="{DynamicResource Brush.Bg}" BorderThickness="0"/>
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>

                                    <!-- نظرة عامّة + أعلى العمليّات -->
                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Padding="16,14" CornerRadius="12"
                                                Background="{DynamicResource Brush.Surface}"
                                                BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1">
                                            <StackPanel>
                                                <TextBlock x:Name="DashOverviewLabel" Text="نظرة عامّة" FontWeight="SemiBold"
                                                           Margin="0,0,0,10"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Grid.Row="0" x:Name="OvHostLbl" Text="المضيف" Foreground="{DynamicResource Brush.TextMuted}" Margin="0,3"/>
                                                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="OvHost" Text="—" Margin="14,3,0,3" FlowDirection="LeftToRight" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Grid.Row="1" x:Name="OvOsLbl" Text="النظام" Foreground="{DynamicResource Brush.TextMuted}" Margin="0,3"/>
                                                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="OvOs" Text="—" Margin="14,3,0,3" FlowDirection="LeftToRight" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Grid.Row="2" x:Name="OvKernelLbl" Text="النواة" Foreground="{DynamicResource Brush.TextMuted}" Margin="0,3"/>
                                                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="OvKernel" Text="—" Margin="14,3,0,3" FlowDirection="LeftToRight" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Grid.Row="3" x:Name="OvCpuLbl" Text="المعالج" Foreground="{DynamicResource Brush.TextMuted}" Margin="0,3"/>
                                                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="OvCpu" Text="—" Margin="14,3,0,3" FlowDirection="LeftToRight" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Grid.Row="4" x:Name="OvIpLbl" Text="العنوان" Foreground="{DynamicResource Brush.TextMuted}" Margin="0,3"/>
                                                    <TextBlock Grid.Row="4" Grid.Column="1" x:Name="OvIp" Text="—" Margin="14,3,0,3" FlowDirection="LeftToRight"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="2" Padding="16,14" CornerRadius="12"
                                                Background="{DynamicResource Brush.Surface}"
                                                BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1">
                                            <DockPanel>
                                                <TextBlock x:Name="DashProcLabel" DockPanel.Dock="Top" Text="أعلى العمليّات"
                                                           FontWeight="SemiBold" Margin="0,0,0,10"/>
                                                <ItemsControl x:Name="DashProcesses">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="0,3" FlowDirection="LeftToRight">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="46"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Text="{Binding CpuText}" Foreground="{DynamicResource Brush.Accent}"
                                                                           FontWeight="SemiBold"/>
                                                                <TextBlock Grid.Column="1" Text="{Binding Command}" Margin="8,0,0,0"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           Foreground="{DynamicResource Brush.Text}"/>
                                                                <TextBlock Grid.Column="2" Text="{Binding MemText}" Margin="10,0,0,0"
                                                                           Foreground="{DynamicResource Brush.TextMuted}"/>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </DockPanel>
                                        </Border>
                                    </Grid>

                                    <!-- التخزين: Treemap + أكبر الملفّات -->
                                    <Border Margin="0,10,0,0" Padding="16,14" CornerRadius="12"
                                            Background="{DynamicResource Brush.Surface}"
                                            BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="16"/>
                                                <ColumnDefinition Width="240"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Treemap: أشرطة نسبيّة للمجلّدات -->
                                            <DockPanel Grid.Column="0">
                                                <TextBlock x:Name="DashTreemapLabel" DockPanel.Dock="Top"
                                                           Text="استهلاك المجلّدات (Treemap)" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                                <TextBlock x:Name="DashTreemapHint" DockPanel.Dock="Top" Text=""
                                                           Foreground="{DynamicResource Brush.TextMuted}" FontSize="11.5"
                                                           Visibility="Collapsed"/>
                                                <ProgressBar x:Name="DashTreemapLoading" DockPanel.Dock="Top" Height="4"
                                                             Margin="0,2,0,4" IsIndeterminate="True" Visibility="Collapsed"
                                                             Foreground="{DynamicResource Brush.Accent}"
                                                             Background="{DynamicResource Brush.Surface2}" BorderThickness="0"/>
                                                <ItemsControl x:Name="DashTreemap">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="0,4" FlowDirection="LeftToRight">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="140"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <ProgressBar Height="16" Minimum="0" Maximum="100"
                                                                             Value="{Binding Percent, Mode=OneWay}"
                                                                             Foreground="{Binding BarBrush}"
                                                                             Background="{DynamicResource Brush.Bg}" BorderThickness="0"/>
                                                                <TextBlock Grid.Column="1" Text="{Binding Label}" Margin="10,0,0,0"
                                                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Grid.Column="2" Text="{Binding SizeText}" Margin="10,0,0,0"
                                                                           VerticalAlignment="Center"
                                                                           Foreground="{DynamicResource Brush.TextMuted}"/>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </DockPanel>

                                            <Border Grid.Column="1" Width="1" Background="{DynamicResource Brush.Border}"/>

                                            <!-- أكبر الملفّات -->
                                            <DockPanel Grid.Column="2">
                                                <TextBlock x:Name="DashLargestLabel" DockPanel.Dock="Top" Text="أكبر الملفّات"
                                                           FontWeight="SemiBold" Margin="0,0,0,10"/>
                                                <!-- كسول: يُحمَّل بزرّ (فحص find على / بطيء) -->
                                                <Button x:Name="DashLargestLoadBtn" DockPanel.Dock="Top" Content="عرض أكبر الملفّات"
                                                        HorizontalAlignment="Left" Padding="12,6" Margin="0,0,0,6"
                                                        Style="{StaticResource AccentButton}" Click="DashLargestLoadBtn_Click"/>
                                                <TextBlock x:Name="DashLargestHint" DockPanel.Dock="Top" Text=""
                                                           Foreground="{DynamicResource Brush.TextMuted}" FontSize="11.5"
                                                           Visibility="Collapsed"/>
                                                <ProgressBar x:Name="DashLargestLoading" DockPanel.Dock="Top" Height="4"
                                                             Margin="0,2,0,4" IsIndeterminate="True" Visibility="Collapsed"
                                                             Foreground="{DynamicResource Brush.Accent}"
                                                             Background="{DynamicResource Brush.Surface2}" BorderThickness="0"/>
                                                <ItemsControl x:Name="DashLargest">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="0,3" FlowDirection="LeftToRight">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis"
                                                                           ToolTip="{Binding Path}" Foreground="{DynamicResource Brush.Text}"/>
                                                                <TextBlock Grid.Column="1" Text="{Binding SizeText}" Margin="10,0,0,0"
                                                                           Foreground="{DynamicResource Brush.TextMuted}"/>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </DockPanel>
                                        </Grid>
                                    </Border>

                                    <!-- الشجرة -->
                                    <Border Margin="0,10,0,0" Padding="16,14" CornerRadius="12"
                                            Background="{DynamicResource Brush.Surface}"
                                            BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1">
                                        <DockPanel>
                                            <TextBlock x:Name="DashTreeLabel" DockPanel.Dock="Top" Text="الشجرة"
                                                       FontWeight="SemiBold" Margin="0,0,0,10"/>
                                            <ProgressBar x:Name="DashTreeLoading" DockPanel.Dock="Top" Height="4"
                                                         Margin="0,0,0,8" IsIndeterminate="True" Visibility="Collapsed"
                                                         Foreground="{DynamicResource Brush.Accent}"
                                                         Background="{DynamicResource Brush.Surface2}" BorderThickness="0"/>
                                            <TreeView x:Name="DashTree" BorderThickness="0" Background="Transparent"
                                                      FlowDirection="LeftToRight" MinHeight="160" MaxHeight="360"
                                                      ItemContainerStyle="{StaticResource TreeItemStyle}"
                                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                      ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                                <TreeView.Resources>
                                                    <Style TargetType="ScrollBar" BasedOn="{StaticResource ThemedScrollBar}"/>
                                                </TreeView.Resources>
                                            </TreeView>
                                        </DockPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- الأقراص -->
                            <ScrollViewer x:Name="ResultScroller" Visibility="Collapsed"
                                          VerticalScrollBarVisibility="Auto" Padding="16">
                                <ScrollViewer.Resources>
                                    <Style TargetType="ScrollBar" BasedOn="{StaticResource ThemedScrollBar}"/>
                                </ScrollViewer.Resources>
                                <StackPanel>
                                    <TextBlock x:Name="DisksLabel" Text="الأقراص والمساحة" Style="{StaticResource SectionLabel}"/>
                                    <ItemsControl x:Name="DisksList" Margin="0,6,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,4" Padding="12,10" CornerRadius="8" Cursor="Hand"
                                                        Background="{DynamicResource Brush.Surface}"
                                                        BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1"
                                                        ToolTip="نقر مزدوج: دخول القرص وتصفّح مجلّداته"
                                                        MouseLeftButtonDown="DiskCard_MouseDown"
                                                        ContextMenuOpening="DiskCard_ContextMenuOpening">
                                                    <Border.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="عرض المجلّدات" Click="DiskOpenFolders_Click">
                                                                <MenuItem.Icon>
                                                                    <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                            <MenuItem Header="عرض أكبر الملفّات" Click="DiskOpenFiles_Click">
                                                                <MenuItem.Icon>
                                                                    <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                            <MenuItem Header="نسخ المسار" Click="DiskCopyPath_Click">
                                                                <MenuItem.Icon>
                                                                    <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                        </ContextMenu>
                                                    </Border.ContextMenu>
                                                    <StackPanel>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="{Binding Mount}" FontWeight="SemiBold"
                                                                           FlowDirection="LeftToRight"/>
                                                                <TextBlock Text="{Binding Filesystem}" FontSize="10.5"
                                                                           Margin="8,0,0,0" VerticalAlignment="Center"
                                                                           Foreground="{DynamicResource Brush.TextMuted}"
                                                                           FlowDirection="LeftToRight"/>
                                                            </StackPanel>
                                                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding SummaryText}"
                                                                       FontSize="11" Foreground="{DynamicResource Brush.TextMuted}"
                                                                       FlowDirection="LeftToRight"/>
                                                            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="10,0,0,0">
                                                                <Button Style="{StaticResource IconButton}" Content="&#xE838;"
                                                                        FontFamily="Segoe MDL2 Assets" FontSize="14" Width="28" Height="26"
                                                                        Click="DiskOpenFolders_Click" ToolTip="عرض المجلّدات"/>
                                                                <Button Style="{StaticResource IconButton}" Content="&#xE7C3;"
                                                                        FontFamily="Segoe MDL2 Assets" FontSize="14" Width="28" Height="26"
                                                                        Click="DiskOpenFiles_Click" ToolTip="عرض أكبر الملفّات"/>
                                                            </StackPanel>
                                                        </Grid>
                                                        <ProgressBar Height="8" Margin="0,8,0,0" Minimum="0" Maximum="100"
                                                                     Value="{Binding UsePercent, Mode=OneWay}"
                                                                     Foreground="{Binding BarBrush}"
                                                                     Background="{DynamicResource Brush.Bg}"
                                                                     BorderThickness="0"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- مستكشف المجلّدات -->
                            <DockPanel x:Name="FoldersPanel" Visibility="Collapsed" Margin="16">
                                <!-- شريط المسار + الأدوات -->
                                <Grid DockPanel.Dock="Top">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="PathBox" FlowDirection="LeftToRight" Text="/"
                                             VerticalContentAlignment="Center"
                                             KeyDown="PathBox_KeyDown"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,0">
                                        <Button x:Name="ScanBtn" Style="{StaticResource AccentButton}"
                                                Content="فحص" Padding="16,7" Click="ScanBtn_Click"/>
                                        <Button x:Name="CopyPathBtn" Content="&#xE8C8;" FontFamily="Segoe MDL2 Assets"
                                                Padding="10,7" Margin="6,0,0,0" Click="CopyPathBtn_Click"
                                                ToolTip="نسخ المسار"/>
                                    </StackPanel>
                                </Grid>

                                <!-- المفضّلة -->
                                <StackPanel DockPanel.Dock="Top" Margin="0,10,0,0">
                                    <TextBlock x:Name="FavoritesLabel" Text="المفضّلة" FontSize="10.5"
                                               Foreground="{DynamicResource Brush.TextMuted}" Margin="2,0,0,4"/>
                                    <WrapPanel x:Name="FavoritesPanel"/>
                                </StackPanel>

                                <!-- ملخّص الجذر -->
                                <Border DockPanel.Dock="Top" Margin="0,12,0,8" Padding="12,8" CornerRadius="8"
                                        Background="{DynamicResource Brush.Surface}"
                                        BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1">
                                    <TextBlock x:Name="FolderSummary" FlowDirection="LeftToRight"
                                               Foreground="{DynamicResource Brush.Text}"/>
                                </Border>

                                <!-- تحميل inline أثناء فحص الشجرة -->
                                <ProgressBar x:Name="FolderScanLoading" DockPanel.Dock="Top" Height="4" Margin="0,0,0,8"
                                             IsIndeterminate="True" Visibility="Collapsed"
                                             Foreground="{DynamicResource Brush.Accent}"
                                             Background="{DynamicResource Brush.Surface2}" BorderThickness="0"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="300" MinWidth="180"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*" MinWidth="180"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- الشجرة (رئيسيّ) -->
                                    <TreeView x:Name="FolderTree" Grid.Column="0" BorderThickness="0" Background="Transparent"
                                              FlowDirection="LeftToRight"
                                              ItemContainerStyle="{StaticResource TreeItemStyle}"
                                              SelectedItemChanged="FolderTree_SelectedItemChanged"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                                              ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                        <TreeView.Resources>
                                            <Style TargetType="ScrollBar" BasedOn="{StaticResource ThemedScrollBar}"/>
                                        </TreeView.Resources>
                                    </TreeView>

                                    <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch"
                                                  Background="Transparent"/>

                                    <!-- تفاصيل المجلّد المختار: ملفّاته المباشرة (لوحة ثانية) -->
                                    <DockPanel Grid.Column="2">
                                        <TextBlock x:Name="FolderDetailHeader" DockPanel.Dock="Top"
                                                   FlowDirection="LeftToRight" TextTrimming="CharacterEllipsis"
                                                   FontWeight="SemiBold" Margin="0,0,0,6"
                                                   Foreground="{DynamicResource Brush.Text}"/>
                                        <Border DockPanel.Dock="Top" Height="1" Margin="0,0,0,6"
                                                Background="{DynamicResource Brush.Border}"/>
                                        <Grid>
                                            <!-- حالة الفراغ: أيقونة + رسالة -->
                                            <StackPanel x:Name="FolderDetailEmpty" VerticalAlignment="Center"
                                                        HorizontalAlignment="Center">
                                                <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" FontSize="34"
                                                           HorizontalAlignment="Center" Opacity="0.7"
                                                           Foreground="{DynamicResource Brush.TextMuted}"/>
                                                <TextBlock x:Name="FolderDetailHint" TextAlignment="Center" Margin="0,10,0,0"
                                                           HorizontalAlignment="Center"
                                                           Foreground="{DynamicResource Brush.TextMuted}"
                                                           Text="اضغط مجلّداً لعرض ملفّاته"/>
                                            </StackPanel>
                                            <!-- حالة التحميل: مؤشّر + نصّ -->
                                            <StackPanel x:Name="FolderDetailLoading" Visibility="Collapsed"
                                                        VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <ProgressBar IsIndeterminate="True" Width="130" Height="6"
                                                             Foreground="{DynamicResource Brush.Accent}"
                                                             Background="{DynamicResource Brush.Surface2}" BorderThickness="0"/>
                                                <TextBlock x:Name="FolderDetailLoadingText" Text="جارٍ التحميل…"
                                                           Margin="0,10,0,0" HorizontalAlignment="Center"
                                                           Foreground="{DynamicResource Brush.TextMuted}"/>
                                            </StackPanel>
                                            <ListBox x:Name="FolderFilesList" BorderThickness="0" Background="Transparent"
                                                     FlowDirection="LeftToRight" SelectionMode="Extended"
                                                     MouseDoubleClick="FolderFilesList_MouseDoubleClick"
                                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                                <ListBox.Resources>
                                                    <Style TargetType="ScrollBar" BasedOn="{StaticResource ThemedScrollBar}"/>
                                                </ListBox.Resources>
                                                <ListBox.ContextMenu>
                                                    <ContextMenu x:Name="DetailMenu">
                                                        <MenuItem x:Name="DetailDownload" Header="تنزيل" Click="DetailDownload_Click">
                                                            <MenuItem.Icon>
                                                                <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                                                            </MenuItem.Icon>
                                                        </MenuItem>
                                                        <MenuItem x:Name="DetailView" Header="عرض (آخر 1000 سطر)" Click="DetailView_Click">
                                                            <MenuItem.Icon>
                                                                <TextBlock Text="&#xE890;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                                                            </MenuItem.Icon>
                                                        </MenuItem>
                                                        <MenuItem x:Name="DetailRename" Header="إعادة تسمية" Click="DetailRename_Click">
                                                            <MenuItem.Icon>
                                                                <TextBlock Text="&#xE8AC;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                                                            </MenuItem.Icon>
                                                        </MenuItem>
                                                        <MenuItem x:Name="DetailCopy" Header="نسخ المسار" Click="DetailCopy_Click">
                                                            <MenuItem.Icon>
                                                                <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                                                            </MenuItem.Icon>
                                                        </MenuItem>
                                                        <MenuItem x:Name="DetailWhichContainer" Header="اعرف الحاوية" Click="DetailWhichContainer_Click">
                                                            <MenuItem.Icon>
                                                                <TextBlock Text="&#xE81E;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                                                            </MenuItem.Icon>
                                                        </MenuItem>
                                                        <Separator/>
                                                        <MenuItem x:Name="DetailDelete" Header="حذف" Click="DetailDelete_Click">
                                                            <MenuItem.Icon>
                                                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                                           Foreground="{DynamicResource Brush.Danger}"/>
                                                            </MenuItem.Icon>
                                                        </MenuItem>
                                                    </ContextMenu>
                                                </ListBox.ContextMenu>
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid MinWidth="200" Margin="0,2">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets"
                                                                       VerticalAlignment="Center" Margin="0,0,8,0"
                                                                       Foreground="{DynamicResource Brush.TextMuted}"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Foreground="{DynamicResource Brush.Text}"
                                                                       ToolTip="{Binding Path}"/>
                                                            <TextBlock Grid.Column="2" Text="{Binding SizeText}" Margin="12,0,0,0"
                                                                       VerticalAlignment="Center"
                                                                       Foreground="{DynamicResource Brush.TextMuted}"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Grid>
                                    </DockPanel>
                                </Grid>
                            </DockPanel>

                            <!-- أكبر الملفّات + العمليّات -->
                            <DockPanel x:Name="FilesPanel" Visibility="Collapsed" Margin="16">
                                <Grid DockPanel.Dock="Top">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="FilesPathBox" FlowDirection="LeftToRight" Text="/"
                                             VerticalContentAlignment="Center" KeyDown="FilesPathBox_KeyDown"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,0">
                                        <Button x:Name="ScanFilesBtn" Style="{StaticResource AccentButton}"
                                                Content="أكبر الملفّات" Padding="16,7" Click="ScanFilesBtn_Click"/>
                                        <Button x:Name="ExportBtn" Content="&#xEDE1;" FontFamily="Segoe MDL2 Assets"
                                                Padding="10,7" Margin="6,0,0,0" Click="ExportBtn_Click"
                                                ToolTip="تصدير CSV"/>
                                    </StackPanel>
                                </Grid>

                                <Grid DockPanel.Dock="Top" Margin="0,8,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="FilesSearch" TextChanged="FilesSearch_TextChanged"
                                             VerticalContentAlignment="Center"/>
                                    <TextBlock x:Name="FilesCount" Grid.Column="1" VerticalAlignment="Center"
                                               Margin="10,0,0,0" FontSize="11" FlowDirection="LeftToRight"
                                               Foreground="{DynamicResource Brush.TextMuted}"/>
                                </Grid>

                                <Grid>
                                <DataGrid x:Name="FilesGrid" AutoGenerateColumns="False" IsReadOnly="True"
                                          FlowDirection="LeftToRight" SelectionMode="Extended"
                                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                          CanUserAddRows="False" CanUserResizeRows="False"
                                          Background="Transparent" BorderThickness="0"
                                          RowBackground="Transparent"
                                          Foreground="{DynamicResource Brush.Text}"
                                          HorizontalGridLinesBrush="{DynamicResource Brush.Border}"
                                          MouseDoubleClick="FilesGrid_MouseDoubleClick">
                                    <DataGrid.Resources>
                                        <Style TargetType="ScrollBar" BasedOn="{StaticResource ThemedScrollBar}"/>
                                        <!-- خليّة تُقصّ بالحذف وتُظهر نصّها كاملاً كتلميح عند المرور (منع تداخل المسار مع الحجم) -->
                                        <Style x:Key="EllipsisCell" TargetType="TextBlock">
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                            <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                                        </Style>
                                    </DataGrid.Resources>
                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}"/>
                                            <Setter Property="Padding" Value="10,7"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>
                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Padding" Value="10,6"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="DataGridCell">
                                                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </DataGrid.CellStyle>
                                    <DataGrid.ContextMenu>
                                        <ContextMenu x:Name="FilesMenu">
                                            <MenuItem x:Name="FileDownload" Header="تنزيل" Click="FileDownload_Click">
                                                <MenuItem.Icon>
                                                    <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem x:Name="FileViewLog" Header="عرض (آخر 1000 سطر)" Click="FileViewLog_Click">
                                                <MenuItem.Icon>
                                                    <TextBlock Text="&#xE890;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem x:Name="FileRename" Header="إعادة تسمية" Click="FileRename_Click">
                                                <MenuItem.Icon>
                                                    <TextBlock Text="&#xE8AC;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem x:Name="FileCopyPath" Header="نسخ المسار" Click="FileCopyPath_Click">
                                                <MenuItem.Icon>
                                                    <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem x:Name="FileWhichContainer" Header="اعرف الحاوية" Click="FileWhichContainer_Click">
                                                <MenuItem.Icon>
                                                    <TextBlock Text="&#xE81E;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <Separator/>
                                            <MenuItem x:Name="FileDelete" Header="حذف" Click="FileDelete_Click">
                                                <MenuItem.Icon>
                                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                               Foreground="{DynamicResource Brush.Danger}"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </DataGrid.ContextMenu>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn x:Name="ColName" Header="الاسم" Binding="{Binding Name}"
                                                            Width="2*" ElementStyle="{StaticResource EllipsisCell}"/>
                                        <DataGridTextColumn x:Name="ColExt" Header="الامتداد" Binding="{Binding Ext}" Width="Auto"/>
                                        <DataGridTextColumn x:Name="ColSize" Header="الحجم" Binding="{Binding SizeText}"
                                                            SortMemberPath="SizeBytes" Width="Auto"/>
                                        <DataGridTextColumn x:Name="ColModified" Header="التعديل" Binding="{Binding ModifiedText}"
                                                            SortMemberPath="ModifiedSort" Width="Auto"/>
                                        <DataGridTextColumn x:Name="ColPath" Header="المسار" Binding="{Binding Path}"
                                                            Width="3*" MinWidth="120"
                                                            ElementStyle="{StaticResource EllipsisCell}"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <!-- حالة الفراغ (أيقونة + رسالة) -->
                                <StackPanel x:Name="FilesEmpty" Visibility="Collapsed"
                                            VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" FontSize="34"
                                               HorizontalAlignment="Center" Opacity="0.7"
                                               Foreground="{DynamicResource Brush.TextMuted}"/>
                                    <TextBlock x:Name="FilesEmptyText" Text="لا ملفّات" TextAlignment="Center"
                                               Margin="0,10,0,0" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource Brush.TextMuted}"/>
                                </StackPanel>
                                <!-- حالة التحميل (مؤشّر) -->
                                <StackPanel x:Name="FilesLoading" Visibility="Collapsed"
                                            VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <ProgressBar IsIndeterminate="True" Width="130" Height="6"
                                                 Foreground="{DynamicResource Brush.Accent}"
                                                 Background="{DynamicResource Brush.Surface2}" BorderThickness="0"/>
                                    <TextBlock x:Name="FilesLoadingText" Text="جارٍ الفحص…"
                                               Margin="0,10,0,0" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource Brush.TextMuted}"/>
                                </StackPanel>
                                </Grid>
                            </DockPanel>

                            <!-- ===== الإدارة: العمليّات + الخدمات + المنافذ ===== -->
                            <ScrollViewer x:Name="MgmtScroller" Visibility="Collapsed"
                                          VerticalScrollBarVisibility="Auto" Padding="16">
                                <ScrollViewer.Resources>
                                    <Style TargetType="ScrollBar" BasedOn="{StaticResource ThemedScrollBar}"/>
                                </ScrollViewer.Resources>
                                <StackPanel>
                                    <!-- العمليّات -->
                                    <Border Padding="16,14" CornerRadius="12" Background="{DynamicResource Brush.Surface}"
                                            BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1">
                                        <DockPanel>
                                            <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                                                <TextBlock x:Name="MgmtProcLabel" Text="العمليّات" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                <Button x:Name="MgmtProcRefresh" HorizontalAlignment="Right" Content="&#xE72C;"
                                                        FontFamily="Segoe MDL2 Assets" Padding="8,5" Click="MgmtProcRefresh_Click" ToolTip="تحديث"/>
                                            </Grid>
                                            <ProgressBar x:Name="MgmtProcLoading" DockPanel.Dock="Top" Height="4" Margin="0,0,0,6"
                                                         IsIndeterminate="True" Visibility="Collapsed"
                                                         Foreground="{DynamicResource Brush.Accent}"
                                                         Background="{DynamicResource Brush.Surface2}" BorderThickness="0"/>
                                            <DataGrid x:Name="MgmtProcesses" AutoGenerateColumns="False" IsReadOnly="True"
                                                      FlowDirection="LeftToRight" SelectionMode="Single" HeadersVisibility="Column"
                                                      GridLinesVisibility="Horizontal" CanUserAddRows="False" MaxHeight="300"
                                                      Background="Transparent" BorderThickness="0" RowBackground="Transparent"
                                                      Foreground="{DynamicResource Brush.Text}"
                                                      HorizontalGridLinesBrush="{DynamicResource Brush.Border}"
                                                      ColumnHeaderStyle="{StaticResource GridColHeader}" CellStyle="{StaticResource GridCell}">
                                                <DataGrid.Resources><Style TargetType="ScrollBar" BasedOn="{StaticResource ThemedScrollBar}"/></DataGrid.Resources>
                                                <DataGrid.ContextMenu>
                                                    <ContextMenu x:Name="MgmtProcMenu">
                                                        <MenuItem x:Name="ProcKill" Header="إنهاء" Click="ProcKill_Click">
                                                            <MenuItem.Icon><TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="14"/></MenuItem.Icon>
                                                        </MenuItem>
                                                        <MenuItem x:Name="ProcKill9" Header="إنهاء إجباريّ (-9)" Click="ProcKill9_Click">
                                                            <MenuItem.Icon><TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource Brush.Danger}"/></MenuItem.Icon>
                                                        </MenuItem>
                                                    </ContextMenu>
                                                </DataGrid.ContextMenu>
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn x:Name="ProcColPid" Header="PID" Binding="{Binding Pid}" Width="Auto"/>
                                                    <DataGridTextColumn x:Name="ProcColUser" Header="المستخدم" Binding="{Binding User}" Width="Auto"/>
                                                    <DataGridTextColumn x:Name="ProcColCpu" Header="CPU%" Binding="{Binding CpuText}" SortMemberPath="Cpu" Width="Auto"/>
                                                    <DataGridTextColumn x:Name="ProcColMem" Header="MEM%" Binding="{Binding MemText}" SortMemberPath="Mem" Width="Auto"/>
                                                    <DataGridTextColumn x:Name="ProcColCmd" Header="الأمر" Binding="{Binding Command}" Width="*"/>
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </DockPanel>
                                    </Border>

                                    <!-- الخدمات -->
                                    <Border Margin="0,10,0,0" Padding="16,14" CornerRadius="12" Background="{DynamicResource Brush.Surface}"
                                            BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1">
                                        <DockPanel>
                                            <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock x:Name="MgmtSvcLabel" Text="الخدمات" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                <TextBox x:Name="MgmtSvcSearch" Grid.Column="1" Margin="12,0" MaxWidth="240"
                                                         HorizontalAlignment="Left" VerticalContentAlignment="Center"
                                                         TextChanged="MgmtSvcSearch_TextChanged"/>
                                                <Button x:Name="MgmtSvcRefresh" Grid.Column="2" Content="&#xE72C;"
                                                        FontFamily="Segoe MDL2 Assets" Padding="8,5" Click="MgmtSvcRefresh_Click" ToolTip="تحديث"/>
                                            </Grid>
                                            <ProgressBar x:Name="MgmtSvcLoading" DockPanel.Dock="Top" Height="4" Margin="0,0,0,6"
                                                         IsIndeterminate="True" Visibility="Collapsed"
                                                         Foreground="{DynamicResource Brush.Accent}"
                                                         Background="{DynamicResource Brush.Surface2}" BorderThickness="0"/>
                                            <DataGrid x:Name="MgmtServices" AutoGenerateColumns="False" IsReadOnly="True"
                                                      FlowDirection="LeftToRight" SelectionMode="Single" HeadersVisibility="Column"
                                                      GridLinesVisibility="Horizontal" CanUserAddRows="False" MaxHeight="340"
                                                      Background="Transparent" BorderThickness="0" RowBackground="Transparent"
                                                      Foreground="{DynamicResource Brush.Text}"
                                                      HorizontalGridLinesBrush="{DynamicResource Brush.Border}"
                                                      ColumnHeaderStyle="{StaticResource GridColHeader}" CellStyle="{StaticResource GridCell}">
                                                <DataGrid.Resources><Style TargetType="ScrollBar" BasedOn="{StaticResource ThemedScrollBar}"/></DataGrid.Resources>
                                                <DataGrid.ContextMenu>
                                                    <ContextMenu x:Name="MgmtSvcMenu">
                                                        <MenuItem x:Name="SvcStart" Header="تشغيل" Click="SvcStart_Click">
                                                            <MenuItem.Icon><TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource Brush.Success}"/></MenuItem.Icon>
                                                        </MenuItem>
                                                        <MenuItem x:Name="SvcStop" Header="إيقاف" Click="SvcStop_Click">
                                                            <MenuItem.Icon><TextBlock Text="&#xE71A;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource Brush.Danger}"/></MenuItem.Icon>
                                                        </MenuItem>
                                                        <MenuItem x:Name="SvcRestart" Header="إعادة تشغيل" Click="SvcRestart_Click">
                                                            <MenuItem.Icon><TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="14"/></MenuItem.Icon>
                                                        </MenuItem>
                                                    </ContextMenu>
                                                </DataGrid.ContextMenu>
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn x:Name="SvcColName" Header="الخدمة" Binding="{Binding Name}" Width="2*"/>
                                                    <DataGridTextColumn x:Name="SvcColActive" Header="الحالة" Binding="{Binding ActiveText}" Width="Auto"/>
                                                    <DataGridTextColumn x:Name="SvcColDesc" Header="الوصف" Binding="{Binding Description}" Width="3*"/>
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </DockPanel>
                                    </Border>

                                    <!-- المنافذ -->
                                    <Border Margin="0,10,0,0" Padding="16,14" CornerRadius="12" Background="{DynamicResource Brush.Surface}"
                                            BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1">
                                        <DockPanel>
                                            <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                                                <TextBlock x:Name="MgmtPortLabel" Text="المنافذ المُنصِتة" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                <Button x:Name="MgmtPortRefresh" HorizontalAlignment="Right" Content="&#xE72C;"
                                                        FontFamily="Segoe MDL2 Assets" Padding="8,5" Click="MgmtPortRefresh_Click" ToolTip="تحديث"/>
                                            </Grid>
                                            <ProgressBar x:Name="MgmtPortLoading" DockPanel.Dock="Top" Height="4" Margin="0,0,0,6"
                                                         IsIndeterminate="True" Visibility="Collapsed"
                                                         Foreground="{DynamicResource Brush.Accent}"
                                                         Background="{DynamicResource Brush.Surface2}" BorderThickness="0"/>
                                            <DataGrid x:Name="MgmtPorts" AutoGenerateColumns="False" IsReadOnly="True"
                                                      FlowDirection="LeftToRight" SelectionMode="Single" HeadersVisibility="Column"
                                                      GridLinesVisibility="Horizontal" CanUserAddRows="False" MaxHeight="260"
                                                      Background="Transparent" BorderThickness="0" RowBackground="Transparent"
                                                      Foreground="{DynamicResource Brush.Text}"
                                                      HorizontalGridLinesBrush="{DynamicResource Brush.Border}"
                                                      ColumnHeaderStyle="{StaticResource GridColHeader}" CellStyle="{StaticResource GridCell}">
                                                <DataGrid.Resources><Style TargetType="ScrollBar" BasedOn="{StaticResource ThemedScrollBar}"/></DataGrid.Resources>
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn x:Name="PortColPort" Header="المنفذ" Binding="{Binding Port}" SortMemberPath="Port" Width="Auto"/>
                                                    <DataGridTextColumn x:Name="PortColAddr" Header="العنوان" Binding="{Binding Address}" Width="2*"/>
                                                    <DataGridTextColumn x:Name="PortColProc" Header="العمليّة" Binding="{Binding Process}" Width="2*"/>
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </DockPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- ===== الحاويات (كلّ حاويات Docker على الخادم) ===== -->
                            <DockPanel x:Name="ContainersPanel" Visibility="Collapsed" Margin="16">
                                <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="ContainersLabel" Text="الحاويات" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="ContainersCount" Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center"
                                               FontSize="12" FlowDirection="LeftToRight"
                                               Foreground="{DynamicResource Brush.TextMuted}"/>
                                    <TextBox x:Name="ContainersSearch" Grid.Column="2" Margin="12,0" MinWidth="220"
                                             HorizontalAlignment="Stretch" VerticalContentAlignment="Center" Padding="8,5"
                                             Tag="بحث في الحاويات…" TextChanged="ContainersSearch_TextChanged"/>
                                    <Button x:Name="ContainersRefresh" Grid.Column="3" Content="&#xE72C;"
                                            FontFamily="Segoe MDL2 Assets" Padding="8,5"
                                            Click="ContainersRefresh_Click" ToolTip="تحديث"/>
                                </Grid>
                                <ProgressBar x:Name="ContainersLoading" DockPanel.Dock="Top" Height="4" Margin="0,0,0,6"
                                             IsIndeterminate="True" Visibility="Collapsed"
                                             Foreground="{DynamicResource Brush.Accent}"
                                             Background="{DynamicResource Brush.Surface2}" BorderThickness="0"/>

                                <Grid>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ScrollViewer.Resources>
                                            <Style TargetType="ScrollBar" BasedOn="{StaticResource ThemedScrollBar}"/>
                                        </ScrollViewer.Resources>
                                        <ItemsControl x:Name="ContainersList">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,8" Padding="14,12" CornerRadius="10"
                                                            Background="{DynamicResource Brush.Surface}"
                                                            BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1">
                                                        <Border.ContextMenu>
                                                            <ContextMenu>
                                                                <MenuItem Header="تسمية…" Click="ContainerRename_Click"/>
                                                                <MenuItem Header="إزالة الاسم" Click="ContainerClearName_Click"
                                                                          Visibility="{Binding HasCustom, Converter={StaticResource Conv.BoolToVis}}"/>
                                                            </ContextMenu>
                                                        </Border.ContextMenu>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <!-- مؤشّر الحالة -->
                                                            <Ellipse Grid.Column="0" Width="9" Height="9" VerticalAlignment="Center" Margin="0,0,12,0">
                                                                <Ellipse.Style>
                                                                    <Style TargetType="Ellipse">
                                                                        <Setter Property="Fill" Value="{DynamicResource Brush.TextMuted}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Running}" Value="True">
                                                                                <Setter Property="Fill" Value="#3FB950"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Ellipse.Style>
                                                            </Ellipse>

                                                            <!-- الاسم المعروض (مخصّص أو حقيقيّ) + الاسم الحقيقيّ عند التخصيص + الصورة + الحالة -->
                                                            <StackPanel Grid.Column="1">
                                                                <TextBlock Text="{Binding DisplayName}" FlowDirection="LeftToRight"
                                                                           FontWeight="SemiBold" FontSize="14" TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Text="{Binding Name}" FlowDirection="LeftToRight" Margin="0,2,0,0"
                                                                           FontSize="11" FontFamily="Consolas, monospace" TextTrimming="CharacterEllipsis"
                                                                           Foreground="{DynamicResource Brush.Accent}"
                                                                           Visibility="{Binding HasCustom, Converter={StaticResource Conv.BoolToVis}}"/>
                                                                <TextBlock FlowDirection="LeftToRight" Margin="0,3,0,0" FontSize="11.5"
                                                                           FontFamily="Consolas, monospace" TextTrimming="CharacterEllipsis"
                                                                           Foreground="{DynamicResource Brush.TextMuted}">
                                                                    <Run Text="{Binding ShortId, Mode=OneWay}"/>
                                                                    <Run Text="  ·  "/>
                                                                    <Run Text="{Binding Image, Mode=OneWay}"/>
                                                                </TextBlock>
                                                                <TextBlock Text="{Binding Status}" FlowDirection="LeftToRight"
                                                                           Margin="0,3,0,0" FontSize="11.5"
                                                                           Foreground="{DynamicResource Brush.TextMuted}"/>
                                                            </StackPanel>

                                                            <!-- دخول -->
                                                            <Button Grid.Column="2" VerticalAlignment="Center" Margin="10,0,0,0"
                                                                    Style="{StaticResource AccentButton}" Content="{Binding EnterLabel}"
                                                                    Tag="{Binding}" IsEnabled="{Binding Running}"
                                                                    Click="ContainerRowEnter_Click"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <StackPanel x:Name="ContainersEmpty" Visibility="Collapsed"
                                                VerticalAlignment="Center" HorizontalAlignment="Center" Margin="24">
                                        <TextBlock Text="&#xE7F4;" FontFamily="Segoe MDL2 Assets" FontSize="30"
                                                   HorizontalAlignment="Center" Opacity="0.65"
                                                   Foreground="{DynamicResource Brush.TextMuted}"/>
                                        <TextBlock x:Name="ContainersEmptyText" Text="لا حاويات" TextAlignment="Center"
                                                   TextWrapping="Wrap" Margin="0,10,0,0" MaxWidth="420"
                                                   Foreground="{DynamicResource Brush.TextMuted}"/>
                                    </StackPanel>
                                </Grid>
                            </DockPanel>
                        </Grid>
                    </DockPanel>
                </Border>

                <!-- ===== محرّر بروفايل الخادم (منبثق) ===== -->
                <Border x:Name="EditorOverlay" Grid.ColumnSpan="3" Background="#88000000"
                        Visibility="Collapsed" MouseLeftButtonDown="EditorOverlay_MouseDown">
                    <Border Width="460" MaxHeight="620" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Style="{StaticResource Card}" Padding="0"
                            MouseLeftButtonDown="EditorCard_MouseDown">
                        <DockPanel>
                            <TextBlock x:Name="EditorTitle" DockPanel.Dock="Top" Text="إضافة خادم" FontSize="16"
                                       FontWeight="SemiBold" Margin="20,18,20,10"/>

                            <Grid DockPanel.Dock="Bottom" Margin="20,14,20,18">
                                <Button HorizontalAlignment="Left" x:Name="EditorCancel" Content="إلغاء" Padding="16,8"
                                        Click="EditorCancel_Click"/>
                                <Button HorizontalAlignment="Right" x:Name="EditorSave" Style="{StaticResource AccentButton}"
                                        Content="حفظ" Padding="20,8" Click="EditorSave_Click"/>
                            </Grid>

                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,0,16,0">
                                <ScrollViewer.Resources>
                                    <Style TargetType="ScrollBar" BasedOn="{StaticResource ThemedScrollBar}"/>
                                </ScrollViewer.Resources>
                                <StackPanel>
                                    <TextBlock x:Name="LblName" Text="الاسم" Style="{StaticResource SectionLabel}"/>
                                    <TextBox x:Name="EdName"/>

                                    <Grid Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="90"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock x:Name="LblHost" Text="المضيف (Host/IP)" Style="{StaticResource SectionLabel}"/>
                                            <TextBox x:Name="EdHost" FlowDirection="LeftToRight"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock x:Name="LblPort" Text="المنفذ" Style="{StaticResource SectionLabel}"/>
                                            <TextBox x:Name="EdPort" FlowDirection="LeftToRight" Text="22"/>
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock x:Name="LblUser" Text="اسم المستخدم" Style="{StaticResource SectionLabel}" Margin="2,12,2,6"/>
                                    <TextBox x:Name="EdUser" FlowDirection="LeftToRight"/>

                                    <TextBlock x:Name="LblAuth" Text="المصادقة" Style="{StaticResource SectionLabel}" Margin="2,12,2,6"/>
                                    <ComboBox x:Name="EdAuth" HorizontalAlignment="Left" Width="200"
                                              SelectionChanged="EdAuth_SelectionChanged"/>

                                    <TextBlock x:Name="LblSecret" Text="كلمة المرور" Style="{StaticResource SectionLabel}" Margin="2,12,2,6"/>
                                    <PasswordBox x:Name="EdPassword" FlowDirection="LeftToRight"/>
                                    <TextBox x:Name="EdKey" FlowDirection="LeftToRight" Visibility="Collapsed"
                                             MinHeight="80" AcceptsReturn="True" TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"/>
                                    <TextBlock x:Name="SecretHint" FontSize="10.5" Margin="2,4,2,0"
                                               Foreground="{DynamicResource Brush.TextMuted}"/>

                                    <TextBlock x:Name="LblKeyPass" Text="عبارة مرور المفتاح" Style="{StaticResource SectionLabel}"
                                               Margin="2,12,2,6" Visibility="Collapsed"/>
                                    <PasswordBox x:Name="EdKeyPass" FlowDirection="LeftToRight" Visibility="Collapsed"/>

                                    <TextBlock x:Name="LblColor" Text="لون مميّز" Style="{StaticResource SectionLabel}" Margin="2,12,2,6"/>
                                    <WrapPanel x:Name="ColorPanel"/>

                                    <CheckBox x:Name="EdUseSudo" Margin="2,14,2,0" Content="استخدم sudo لأوامر Docker"/>
                                    <TextBlock x:Name="SudoHint" FontSize="10.5" Margin="2,4,2,0" TextWrapping="Wrap"
                                               Foreground="{DynamicResource Brush.TextMuted}"/>

                                    <TextBlock x:Name="LblNotes" Text="ملاحظات" Style="{StaticResource SectionLabel}" Margin="2,12,2,6"/>
                                    <TextBox x:Name="EdNotes" MinHeight="48" AcceptsReturn="True" TextWrapping="Wrap"
                                             Margin="0,0,0,8"/>
                                </StackPanel>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Border>

                <!-- ===== حوار إعادة التسمية ===== -->
                <Border x:Name="RenameOverlay" Grid.ColumnSpan="3" Background="#88000000"
                        Visibility="Collapsed" MouseLeftButtonDown="RenameOverlay_MouseDown">
                    <Border Width="400" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Style="{StaticResource Card}" Padding="20" MouseLeftButtonDown="EditorCard_MouseDown">
                        <StackPanel>
                            <TextBlock x:Name="RenameTitle" Text="إعادة تسمية" FontSize="16" FontWeight="SemiBold"
                                       Margin="0,0,0,14"/>
                            <TextBox x:Name="RenameBox" FlowDirection="LeftToRight" KeyDown="RenameBox_KeyDown"/>
                            <Grid Margin="0,18,0,0">
                                <Button HorizontalAlignment="Left" x:Name="RenameCancel" Content="إلغاء" Padding="16,8"
                                        Click="RenameCancel_Click"/>
                                <Button HorizontalAlignment="Right" x:Name="RenameSave" Style="{StaticResource AccentButton}"
                                        Content="حفظ" Padding="20,8" Click="RenameSave_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- ===== عارض السجلّ (آخر N سطر + بحث) ===== -->
                <Border x:Name="LogOverlay" Grid.ColumnSpan="3" Background="#88000000"
                        Visibility="Collapsed" MouseLeftButtonDown="LogOverlay_MouseDown">
                    <Border Width="760" MaxHeight="620" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Style="{StaticResource Card}" Padding="0" MouseLeftButtonDown="EditorCard_MouseDown">
                        <DockPanel>
                            <Grid DockPanel.Dock="Top" Margin="18,14,12,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="LogTitle" VerticalAlignment="Center" FontWeight="SemiBold"
                                           FlowDirection="LeftToRight" TextTrimming="CharacterEllipsis"/>
                                <Button Grid.Column="1" Style="{StaticResource ChromeButton}"
                                        Content="&#xE8BB;" Click="LogClose_Click"/>
                            </Grid>
                            <Grid DockPanel.Dock="Top" Margin="18,0,18,10">
                                <TextBox x:Name="LogSearch" VerticalContentAlignment="Center"
                                         KeyDown="LogSearch_KeyDown"/>
                            </Grid>
                            <Border DockPanel.Dock="Top" Height="1" Background="{DynamicResource Brush.Border}"/>
                            <TextBox x:Name="LogContent" IsReadOnly="True" FlowDirection="LeftToRight"
                                     FontFamily="Consolas, monospace" FontSize="12"
                                     Background="Transparent" BorderThickness="0" Margin="8"
                                     TextWrapping="NoWrap" AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                                <TextBox.Resources>
                                    <Style TargetType="ScrollBar" BasedOn="{StaticResource ThemedScrollBar}"/>
                                </TextBox.Resources>
                            </TextBox>
                        </DockPanel>
                    </Border>
                </Border>

                <!-- ===== لوحة معلومات الحاوية (Docker) — نتيجة «اعرف الحاوية» ===== -->
                <Border x:Name="ContainerOverlay" Grid.ColumnSpan="3" Background="#88000000"
                        Visibility="Collapsed" MouseLeftButtonDown="ContainerOverlay_MouseDown">
                    <Border Width="540" MaxHeight="660" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Style="{StaticResource Card}" Padding="0" MouseLeftButtonDown="EditorCard_MouseDown">
                        <DockPanel>
                            <!-- ترويسة: أيقونة + الاسم الكبير + نوع الطبقة/الحجم + إغلاق -->
                            <Grid DockPanel.Dock="Top" Margin="20,16,12,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="44" Height="44" CornerRadius="12" VerticalAlignment="Top"
                                        Background="{DynamicResource Brush.Surface2}">
                                    <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="{DynamicResource Brush.Accent}"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock x:Name="ContainerHeaderLabel" Text="الحاوية المالكة" FontSize="12"
                                               Foreground="{DynamicResource Brush.TextMuted}"/>
                                    <TextBlock x:Name="ContainerName" Text="—" FontSize="19" FontWeight="SemiBold"
                                               FlowDirection="LeftToRight" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                    <TextBlock x:Name="ContainerKindLine" Text="" FontSize="11.5" FlowDirection="LeftToRight"
                                               Foreground="{DynamicResource Brush.TextMuted}" TextTrimming="CharacterEllipsis"
                                               Margin="0,3,0,0" FontFamily="Consolas, monospace"/>
                                </StackPanel>
                                <Button Grid.Column="2" VerticalAlignment="Top" Style="{StaticResource ChromeButton}"
                                        Content="&#xE8BB;" Click="ContainerClose_Click"/>
                            </Grid>

                            <!-- مسار الملفّ محلّ الاستعلام -->
                            <Border DockPanel.Dock="Top" Margin="20,0,20,12" Padding="10,7" CornerRadius="6"
                                    Background="{DynamicResource Brush.Bg}"
                                    BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1">
                                <TextBlock x:Name="ContainerPath" FlowDirection="LeftToRight" FontFamily="Consolas, monospace"
                                           FontSize="11.5" TextWrapping="Wrap" Foreground="{DynamicResource Brush.TextMuted}"/>
                            </Border>

                            <Border DockPanel.Dock="Top" Height="1" Background="{DynamicResource Brush.Border}"/>

                            <!-- أزرار الأسفل -->
                            <Grid DockPanel.Dock="Bottom" Margin="20,12,20,16">
                                <Button x:Name="ContainerCopyId" HorizontalAlignment="Left" Content="نسخ المعرّف"
                                        Padding="14,8" Click="ContainerCopyId_Click"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button x:Name="ContainerCopyName" Content="نسخ الاسم" Padding="14,8"
                                            Click="ContainerCopyName_Click"/>
                                    <Button x:Name="ContainerEnter" Margin="8,0,0,0" IsEnabled="False"
                                            Style="{StaticResource AccentButton}" Content="دخول الحاوية"
                                            Click="ContainerEnter_Click"/>
                                </StackPanel>
                            </Grid>

                            <!-- الجسم: قائمة الحاويات / فراغ / تحميل -->
                            <Grid Margin="0,12,0,0">
                                <ScrollViewer x:Name="ContainerBody" VerticalScrollBarVisibility="Auto" Padding="20,0">
                                    <ScrollViewer.Resources>
                                        <Style TargetType="ScrollBar" BasedOn="{StaticResource ThemedScrollBar}"/>
                                    </ScrollViewer.Resources>
                                    <ItemsControl x:Name="ContainerList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,10" Padding="14,12" CornerRadius="10"
                                                        Background="{DynamicResource Brush.Bg}"
                                                        BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1">
                                                    <StackPanel>
                                                        <!-- الاسم + مؤشّر الحالة -->
                                                        <Grid>
                                                            <StackPanel Orientation="Horizontal">
                                                                <Ellipse Width="9" Height="9" VerticalAlignment="Center">
                                                                    <Ellipse.Style>
                                                                        <Style TargetType="Ellipse">
                                                                            <Setter Property="Fill" Value="{DynamicResource Brush.TextMuted}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Running}" Value="True">
                                                                                    <Setter Property="Fill" Value="#3FB950"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Ellipse.Style>
                                                                </Ellipse>
                                                                <TextBlock Text="{Binding Name}" FlowDirection="LeftToRight"
                                                                           Margin="8,0,0,0" FontWeight="SemiBold" FontSize="14"
                                                                           VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                            <TextBlock Text="{Binding Status}" HorizontalAlignment="Right"
                                                                       VerticalAlignment="Center" FontSize="12" FlowDirection="LeftToRight"
                                                                       Foreground="{DynamicResource Brush.TextMuted}"/>
                                                        </Grid>

                                                        <!-- شارات Coolify / Compose -->
                                                        <WrapPanel Margin="0,10,0,0">
                                                            <Border Visibility="{Binding HasCoolify, Converter={StaticResource Conv.BoolToVis}}"
                                                                    Margin="0,0,6,6" Padding="8,3" CornerRadius="5"
                                                                    Background="{DynamicResource Brush.Surface2}">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="Coolify" FontSize="10.5" FontWeight="SemiBold"
                                                                               VerticalAlignment="Center" FlowDirection="LeftToRight"
                                                                               Foreground="{DynamicResource Brush.Accent}"/>
                                                                    <TextBlock Text="{Binding CoolifyName}" FlowDirection="LeftToRight"
                                                                               Margin="6,0,0,0" FontSize="11" VerticalAlignment="Center"
                                                                               Foreground="{DynamicResource Brush.Text}"/>
                                                                </StackPanel>
                                                            </Border>
                                                            <Border Visibility="{Binding HasCompose, Converter={StaticResource Conv.BoolToVis}}"
                                                                    Margin="0,0,6,6" Padding="8,3" CornerRadius="5"
                                                                    Background="{DynamicResource Brush.Surface2}">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="Compose" FontSize="10.5" FontWeight="SemiBold"
                                                                               VerticalAlignment="Center" FlowDirection="LeftToRight"
                                                                               Foreground="{DynamicResource Brush.TextMuted}"/>
                                                                    <TextBlock Text="{Binding ComposeProject}" FlowDirection="LeftToRight"
                                                                               Margin="6,0,0,0" FontSize="11" VerticalAlignment="Center"
                                                                               Foreground="{DynamicResource Brush.Text}"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </WrapPanel>

                                                        <!-- الصورة -->
                                                        <Grid Margin="0,8,0,0"
                                                              Visibility="{Binding HasImage, Converter={StaticResource Conv.BoolToVis}}">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding ImageLabel}" FontSize="12"
                                                                       Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Top"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding Image}" FlowDirection="LeftToRight"
                                                                       Margin="10,0,0,0" FontSize="12" TextWrapping="Wrap"
                                                                       FontFamily="Consolas, monospace"
                                                                       Foreground="{DynamicResource Brush.Text}"/>
                                                        </Grid>

                                                        <!-- ملاحظة الملكيّة (طبقة كتابة / حجم مُركَّب) -->
                                                        <TextBlock Text="{Binding OwnershipText}" Margin="0,10,0,0" TextWrapping="Wrap"
                                                                   FontSize="12" Foreground="{DynamicResource Brush.TextMuted}"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <!-- فراغ: لا حاوية / خارج Docker / خطأ -->
                                <StackPanel x:Name="ContainerEmpty" Visibility="Collapsed"
                                            VerticalAlignment="Center" HorizontalAlignment="Center" Margin="24">
                                    <TextBlock Text="&#xEDA2;" FontFamily="Segoe MDL2 Assets" FontSize="30"
                                               HorizontalAlignment="Center" Opacity="0.65"
                                               Foreground="{DynamicResource Brush.TextMuted}"/>
                                    <TextBlock x:Name="ContainerEmptyText" TextAlignment="Center" TextWrapping="Wrap"
                                               Margin="0,10,0,0" MaxWidth="400"
                                               Foreground="{DynamicResource Brush.TextMuted}"/>
                                </StackPanel>

                                <!-- تحميل -->
                                <StackPanel x:Name="ContainerLoading" Visibility="Collapsed"
                                            VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <ProgressBar IsIndeterminate="True" Width="130" Height="6"
                                                 Foreground="{DynamicResource Brush.Accent}"
                                                 Background="{DynamicResource Brush.Surface2}" BorderThickness="0"/>
                                    <TextBlock x:Name="ContainerLoadingText" Text="جارٍ تحديد الحاوية…"
                                               Margin="0,10,0,0" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource Brush.TextMuted}"/>
                                </StackPanel>
                            </Grid>
                        </DockPanel>
                    </Border>
                </Border>

                <!-- ===== تسمية الحاوية باسم مخصّص ===== -->
                <Border x:Name="NameOverlay" Grid.ColumnSpan="3" Background="#88000000"
                        Visibility="Collapsed" MouseLeftButtonDown="NameOverlay_MouseDown">
                    <Border Width="440" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Style="{StaticResource Card}" Padding="22" MouseLeftButtonDown="EditorCard_MouseDown">
                        <StackPanel>
                            <TextBlock x:Name="NameTitle" Text="تسمية الحاوية" FontSize="15" FontWeight="SemiBold"
                                       Margin="0,0,0,12"/>
                            <TextBox x:Name="NameInput" VerticalContentAlignment="Center" Padding="8,6"
                                     KeyDown="NameInput_KeyDown"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,16,0,0">
                                <Button x:Name="NameSave" Content="حفظ" Style="{StaticResource AccentButton}"
                                        Padding="20,8" Click="NameSave_Click"/>
                                <Button x:Name="NameCancel" Content="إلغاء" Margin="8,0,0,0" Padding="18,8"
                                        Click="NameCancel_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- ===== حوار تأكيد الحذف (مُنسّق — يحلّ محلّ MessageBox) ===== -->
                <Border x:Name="ConfirmOverlay" Grid.ColumnSpan="3" Background="#88000000"
                        Visibility="Collapsed" MouseLeftButtonDown="ConfirmOverlay_MouseDown">
                    <Border Width="430" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Style="{StaticResource Card}" Padding="24" MouseLeftButtonDown="EditorCard_MouseDown">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Border Width="40" Height="40" CornerRadius="20" VerticalAlignment="Center"
                                        Background="{DynamicResource Brush.Surface2}">
                                    <TextBlock x:Name="ConfirmIcon" Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="19" HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="{DynamicResource Brush.Danger}"/>
                                </Border>
                                <TextBlock x:Name="ConfirmTitle" Text="تأكيد الحذف" FontSize="16" FontWeight="SemiBold"
                                           VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </StackPanel>
                            <TextBlock x:Name="ConfirmMessage" TextWrapping="Wrap"
                                       Foreground="{DynamicResource Brush.Text}"/>
                            <Border Margin="0,10,0,0" Padding="10,7" CornerRadius="6"
                                    Background="{DynamicResource Brush.Bg}"
                                    BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1">
                                <TextBlock x:Name="ConfirmPath" FlowDirection="LeftToRight" FontFamily="Consolas, monospace"
                                           FontSize="12" TextWrapping="Wrap"
                                           Foreground="{DynamicResource Brush.TextMuted}"/>
                            </Border>
                            <Grid Margin="0,20,0,0">
                                <Button x:Name="ConfirmCancel" HorizontalAlignment="Left" Content="إلغاء" Padding="16,8"
                                        Click="ConfirmCancel_Click"/>
                                <Button x:Name="ConfirmOk" HorizontalAlignment="Right" Content="حذف" Padding="22,8"
                                        Click="ConfirmOk_Click" Style="{StaticResource DangerButton}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- ===== لوحة الخوادم المنبثقة (تفتح بالمرور على الشريط) ===== -->
                <Border x:Name="ServerFlyout" Grid.ColumnSpan="3" Visibility="Collapsed"
                        HorizontalAlignment="Left" Width="300" VerticalAlignment="Stretch"
                        MouseLeave="ServerFlyout_MouseLeave">
                    <Border Style="{StaticResource Card}" Padding="12">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" BlurRadius="24" ShadowDepth="0" Opacity="0.45"/>
                        </Border.Effect>
                        <DockPanel>
                            <Grid DockPanel.Dock="Top" Margin="2,0,0,10">
                                <TextBlock x:Name="ServersHeader" Text="الخوادم" FontWeight="SemiBold" FontSize="14"
                                           VerticalAlignment="Center"/>
                                <Button x:Name="AddBtn" HorizontalAlignment="Right" Style="{StaticResource IconButton}"
                                        Content="＋" FontSize="19" Foreground="{DynamicResource Brush.Accent}"
                                        Click="AddBtn_Click"/>
                            </Grid>

                            <TextBox x:Name="SearchBox" DockPanel.Dock="Top" Margin="0,0,0,10"
                                     TextChanged="SearchBox_TextChanged"/>

                            <Grid DockPanel.Dock="Bottom" Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="ConnectBtn" Grid.Column="0" Style="{StaticResource AccentButton}"
                                        Content="اتّصال" Click="ConnectBtn_Click"/>
                                <Button x:Name="TestBtn" Grid.Column="2" Content="اختبار" Padding="14,8"
                                        Click="TestBtn_Click"/>
                            </Grid>

                            <ListBox x:Name="ServerList" Margin="0,0,0,2"
                                     MouseDoubleClick="ServerList_MouseDoubleClick"
                                     SelectionChanged="ServerList_SelectionChanged">
                                <ListBox.ContextMenu>
                                    <ContextMenu x:Name="ServerListMenu">
                                        <MenuItem x:Name="CtxEdit" Header="تعديل" Click="EditBtn_Click">
                                            <MenuItem.Icon>
                                                <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem x:Name="CtxDuplicate" Header="نسخ" Click="DuplicateBtn_Click">
                                            <MenuItem.Icon>
                                                <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <Separator/>
                                        <MenuItem x:Name="CtxDelete" Header="حذف" Click="DeleteBtn_Click">
                                            <MenuItem.Icon>
                                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                           Foreground="{DynamicResource Brush.Danger}"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </ContextMenu>
                                </ListBox.ContextMenu>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Width="10" Height="10" CornerRadius="5" VerticalAlignment="Center"
                                                    Margin="0,0,10,0" Background="{Binding EffectiveColor}"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"/>
                                                <TextBlock Text="{Binding DisplaySubtitle}" FontSize="10.5"
                                                           Foreground="{DynamicResource Brush.TextMuted}"
                                                           FlowDirection="LeftToRight" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>
                </Border>

            </Grid>
        </Grid>
    </Border>
</Window>
