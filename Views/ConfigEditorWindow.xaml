<Window x:Class="TerminalLauncher.Views.ConfigEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="محرّر الإعدادات" Height="640" Width="820" MinHeight="420" MinWidth="560"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Bg}"
        FontFamily="{DynamicResource Font.Ui}" FontSize="{DynamicResource Size.Ui}"
        TextOptions.TextFormattingMode="Ideal" UseLayoutRounding="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- شريط علويّ: تبويبات (الواجهة/النظام) + تنسيق/تحقّق -->
        <Border Grid.Row="0" Padding="12,9" Background="{DynamicResource Brush.Surface}"
                BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <ToggleButton x:Name="TabUi" Style="{StaticResource SegToggle}" Padding="14,6"
                                  Click="TabUi_Click"/>
                    <ToggleButton x:Name="TabSystem" Style="{StaticResource SegToggle}" Padding="14,6" Margin="6,0,0,0"
                                  Click="TabSystem_Click"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="FormatBtn" Padding="12,6" Click="Format_Click"/>
                    <Button x:Name="ValidateBtn" Padding="12,6" Margin="6,0,0,0" Click="Validate_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- المحرّر (AvalonEdit) — تلوين مفتاح/قيمة، أرقام أسطر، خطّ أحاديّ -->
        <avalon:TextEditor x:Name="Editor" Grid.Row="1"
                           ShowLineNumbers="True" WordWrap="False"
                           FontFamily="{DynamicResource Font.Mono}" FontSize="13.5"
                           FlowDirection="LeftToRight"
                           Background="{DynamicResource Brush.TerminalBg}"
                           Foreground="{DynamicResource Brush.Text}"
                           HorizontalScrollBarVisibility="Auto"
                           VerticalScrollBarVisibility="Auto" Padding="6,4">
            <avalon:TextEditor.Resources>
                <Style TargetType="ScrollBar" BasedOn="{StaticResource ThemedScrollBar}"/>
            </avalon:TextEditor.Resources>
        </avalon:TextEditor>

        <!-- شريط الحالة (نتيجة التحقّق) + الأزرار -->
        <Border Grid.Row="2" Padding="12,9" Background="{DynamicResource Brush.Surface}"
                BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="StatusChip" Grid.Column="0" CornerRadius="{DynamicResource Radius.Control}"
                        Padding="10,5" HorizontalAlignment="Left" VerticalAlignment="Center"
                        Background="{DynamicResource Brush.Surface2}">
                    <TextBlock x:Name="StatusText" FlowDirection="LeftToRight" TextTrimming="CharacterEllipsis"
                               MaxWidth="420" Foreground="{DynamicResource Brush.TextMuted}"/>
                </Border>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="ReloadBtn" Padding="12,6" Click="Reload_Click"/>
                    <Button x:Name="SaveBtn" Padding="14,6" Margin="6,0,0,0" Style="{StaticResource AccentButton}" Click="Save_Click"/>
                    <Button x:Name="CloseBtn" Padding="12,6" Margin="6,0,0,0" Click="Close_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
