<Window x:Class="TerminalLauncher.Views.ContainerExplorerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:TerminalLauncher.Controls"
        xmlns:loc="clr-namespace:TerminalLauncher.Services"
        xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="مستكشف الحاوية" Height="640" Width="960" MinHeight="380" MinWidth="560"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Brush.Bg}"
        TextOptions.TextFormattingMode="Ideal"
        UseLayoutRounding="True">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- شريط المسار + الأدوات -->
        <Border Grid.Row="0" Padding="12,10" Background="{DynamicResource Brush.Surface}"
                BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1">
            <DockPanel>
                <TextBox DockPanel.Dock="Top" x:Name="HeaderText" IsReadOnly="True" IsTabStop="False"
                         FontWeight="SemiBold" FontSize="13" FlowDirection="LeftToRight"
                         Foreground="{DynamicResource Brush.Text}" Background="Transparent"
                         BorderThickness="0" Padding="0" Margin="2,0,2,8" TextWrapping="NoWrap"
                         HorizontalScrollBarVisibility="Hidden"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="HomeBtn" Grid.Column="0" Content="&#xE80F;" FontFamily="Segoe MDL2 Assets"
                            Padding="9,5" Click="Home_Click" ToolTip="الجذر (/)"/>
                    <Button x:Name="UpBtn" Grid.Column="1" Margin="6,0,0,0" Content="&#xE74A;"
                            FontFamily="Segoe MDL2 Assets" Padding="9,5" Click="Up_Click" ToolTip="أعلى"/>
                    <TextBox x:Name="PathBox" Grid.Column="2" Margin="8,0" VerticalContentAlignment="Center"
                             FlowDirection="LeftToRight" FontFamily="Consolas, monospace" KeyDown="PathBox_KeyDown"/>
                    <Button x:Name="NewFolderBtn" Grid.Column="3" Content="&#xE8F4;" FontFamily="Segoe MDL2 Assets"
                            Padding="9,5" Click="NewFolder_Click" ToolTip="مجلّد جديد هنا"/>
                    <Button x:Name="UploadBtn" Grid.Column="4" Margin="6,0,0,0" Content="&#xE898;"
                            FontFamily="Segoe MDL2 Assets" Padding="9,5" Click="Upload_Click" ToolTip="رفع ملفّ هنا"/>
                    <Button x:Name="ConsoleHereBtn" Grid.Column="5" Margin="6,0,0,0" Content="الكونسول هنا"
                            Padding="12,5" Click="ConsoleHere_Click" ToolTip="cd إلى هذا المسار في الكونسول"/>
                    <Button x:Name="RefreshBtn" Grid.Column="6" Margin="6,0,0,0" Content="&#xE72C;"
                            FontFamily="Segoe MDL2 Assets" Padding="9,5" Click="Refresh_Click" ToolTip="تحديث"/>
                    <Button x:Name="OrientationBtn" Grid.Column="7" Margin="6,0,0,0" Content="&#x2B0D;"
                            Padding="9,5" Click="Orientation_Click" ToolTip="اتّجاه الكونسول (أسفل/جانب)"/>
                    <ToggleButton x:Name="ConsoleToggle" Grid.Column="8" Margin="6,0,0,0" IsChecked="True"
                                  Content="&#xE756;" FontFamily="Segoe MDL2 Assets" Padding="9,5"
                                  Click="ConsoleToggle_Click" ToolTip="إظهار/إخفاء الكونسول"/>
                </Grid>
            </DockPanel>
        </Border>

        <!-- مضيف التقسيم: يُضبَط تخطيطه (صفوف/أعمدة) في الكود حسب الاتّجاه وحالة الكونسول -->
        <Grid Grid.Row="1" x:Name="SplitHost">
            <!-- قائمة الملفّات -->
            <DockPanel x:Name="FileArea">
                <!-- ترويسة أعمدة قابلة للنقر للفرز (الاسم/النوع/الحجم/عُدِّل) -->
                <Border DockPanel.Dock="Top" Padding="8,3" Background="{DynamicResource Brush.Surface}"
                        BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1">
                    <Border.Resources>
                        <Style x:Key="ColHeaderButton" TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="4,3"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="FontSize" Value="11.5"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Resources>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="34"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="HdrName" Grid.Column="1" Tag="Name" Click="SortHeader_Click"
                                Style="{StaticResource ColHeaderButton}" HorizontalContentAlignment="Left"/>
                        <Button x:Name="HdrType" Grid.Column="2" Tag="Type" Click="SortHeader_Click"
                                Style="{StaticResource ColHeaderButton}" HorizontalContentAlignment="Right"/>
                        <Button x:Name="HdrSize" Grid.Column="3" Tag="Size" Click="SortHeader_Click"
                                Style="{StaticResource ColHeaderButton}" HorizontalContentAlignment="Right"/>
                        <Button x:Name="HdrModified" Grid.Column="4" Tag="Modified" Click="SortHeader_Click"
                                Style="{StaticResource ColHeaderButton}" HorizontalContentAlignment="Right"/>
                    </Grid>
                </Border>
                <Grid>
                <ProgressBar x:Name="Loading" VerticalAlignment="Top" Height="3" IsIndeterminate="True"
                             Visibility="Collapsed" Foreground="{DynamicResource Brush.Accent}"
                             Background="Transparent" BorderThickness="0"/>
                <ListBox x:Name="FileList" Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         MouseDoubleClick="FileList_MouseDoubleClick" KeyDown="FileList_KeyDown">
                    <ListBox.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource ThemedScrollBar}"/>
                    </ListBox.Resources>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="8,5"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="{loc:T ctx.open}" Click="MenuOpen_Click">
                                            <MenuItem.Icon><TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="14"/></MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="{loc:T ctx.edit}" Click="MenuEdit_Click"
                                                  Visibility="{Binding IsFile, Converter={StaticResource Conv.BoolToVis}}">
                                            <MenuItem.Icon><TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="14"/></MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="{loc:T ctx.download}" Click="MenuDownload_Click"
                                                  Visibility="{Binding IsFile, Converter={StaticResource Conv.BoolToVis}}">
                                            <MenuItem.Icon><TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="14"/></MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="{loc:T ctx.consoleHere}" Click="MenuConsoleHere_Click"
                                                  Visibility="{Binding IsDir, Converter={StaticResource Conv.BoolToVis}}">
                                            <MenuItem.Icon><TextBlock Text="&#xE756;" FontFamily="Segoe MDL2 Assets" FontSize="14"/></MenuItem.Icon>
                                        </MenuItem>
                                        <Separator/>
                                        <MenuItem Header="{loc:T ctx.rename}" InputGestureText="R" Click="MenuRename_Click">
                                            <MenuItem.Icon><TextBlock Text="&#xE8AC;" FontFamily="Segoe MDL2 Assets" FontSize="14"/></MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="{loc:T dlg.delete}" InputGestureText="Del"
                                                  Style="{StaticResource MenuItem.Danger}" Click="MenuDelete_Click">
                                            <MenuItem.Icon><TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource Brush.Danger}"/></MenuItem.Icon>
                                        </MenuItem>
                                    </ContextMenu>
                                </Grid.ContextMenu>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="34"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Glyph}" FontFamily="Segoe MDL2 Assets" FontSize="15"
                                           VerticalAlignment="Center" Width="24"
                                           Foreground="{DynamicResource Brush.Accent}"/>
                                <TextBlock Grid.Column="1" Text="{Binding Name}" FlowDirection="LeftToRight" VerticalAlignment="Center"
                                           FontSize="13" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource Brush.Text}"/>
                                <TextBlock Grid.Column="2" Text="{Binding TypeText}" VerticalAlignment="Center" FontSize="11.5"
                                           HorizontalAlignment="Right" TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource Brush.TextMuted}"/>
                                <TextBlock Grid.Column="3" Text="{Binding SizeText}" VerticalAlignment="Center" FontSize="11.5"
                                           HorizontalAlignment="Right" FlowDirection="LeftToRight" Margin="10,0,0,0"
                                           FontFamily="Consolas, monospace" Foreground="{DynamicResource Brush.TextMuted}"/>
                                <TextBlock Grid.Column="4" Text="{Binding Modified}" VerticalAlignment="Center" FontSize="11.5"
                                           HorizontalAlignment="Right" FlowDirection="LeftToRight" Margin="10,0,4,0"
                                           TextTrimming="CharacterEllipsis" Foreground="{DynamicResource Brush.TextMuted}"/>
                                <!-- زرّ الثلاث نقاط: يظهر عند المرور ويفتح قائمة الصفّ نفسها -->
                                <Button Grid.Column="5" ctrl:MenuButton.IsMenuTrigger="True" VerticalAlignment="Center">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource KebabButton}">
                                            <Setter Property="Visibility" Value="Hidden"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <StackPanel x:Name="EmptyBox" Visibility="Collapsed" VerticalAlignment="Center"
                            HorizontalAlignment="Center" Margin="24">
                    <TextBlock Text="&#xEC50;" FontFamily="Segoe MDL2 Assets" FontSize="30" HorizontalAlignment="Center"
                               Opacity="0.6" Foreground="{DynamicResource Brush.TextMuted}"/>
                    <TextBlock x:Name="EmptyText" TextAlignment="Center" TextWrapping="Wrap" Margin="0,10,0,0"
                               MaxWidth="460" Foreground="{DynamicResource Brush.TextMuted}"/>
                </StackPanel>
                </Grid>
            </DockPanel>

            <!-- فاصل قابل للسحب (اتّجاهه يُضبَط في الكود) -->
            <GridSplitter x:Name="ConsoleSplitter" Height="6" HorizontalAlignment="Stretch"
                          VerticalAlignment="Center" Background="{DynamicResource Brush.Border}"
                          ResizeBehavior="PreviousAndNext" ResizeDirection="Rows" ShowsPreview="False"/>

            <!-- الكونسول التفاعليّ داخل الحاوية: شريط تبويبات + محتوى التبويب النشط -->
            <Border x:Name="ConsoleHost" BorderThickness="0,1,0,0"
                    BorderBrush="{DynamicResource Brush.Border}">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="{DynamicResource Brush.Surface}"
                            BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1" Padding="4,3">
                        <DockPanel>
                            <ComboBox DockPanel.Dock="Right" x:Name="ShellPicker" Width="120" Margin="4,0,0,0"
                                      VerticalAlignment="Center" SelectedIndex="0"
                                      ToolTip="صدفة التيرمنال الجديد"/>
                            <Button DockPanel.Dock="Right" x:Name="AddConsoleBtn" Content="&#xE710;"
                                    FontFamily="Segoe MDL2 Assets" Padding="8,4" Click="AddConsole_Click"
                                    ToolTip="تيرمنال جديد"/>
                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                <ItemsControl x:Name="ConsoleTabsBar">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="2,0" CornerRadius="6" Padding="9,3"
                                                    MouseLeftButtonDown="ConsoleTab_Click" Cursor="Hand">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource Brush.Bg}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Border.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="{loc:T ctx.rename}" Click="ConsoleTabRename_Click">
                                                            <MenuItem.Icon><TextBlock Text="&#xE8AC;" FontFamily="Segoe MDL2 Assets" FontSize="14"/></MenuItem.Icon>
                                                        </MenuItem>
                                                        <MenuItem Header="{loc:T ctx.close}" Click="ConsoleTabCloseMenu_Click">
                                                            <MenuItem.Icon><TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="14"/></MenuItem.Icon>
                                                        </MenuItem>
                                                    </ContextMenu>
                                                </Border.ContextMenu>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="12.5"
                                                               Foreground="{DynamicResource Brush.Text}"/>
                                                    <Button Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="9"
                                                            Margin="8,0,0,0" Padding="3,1" Background="Transparent"
                                                            BorderThickness="0" Click="ConsoleTabClose_Click"
                                                            Foreground="{DynamicResource Brush.TextMuted}"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                    <Grid x:Name="ConsoleContent"/>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ===== عارض محتوى الملفّ ===== -->
        <Border x:Name="FileViewerOverlay" Grid.RowSpan="2" Background="#99000000"
                Visibility="Collapsed" MouseLeftButtonDown="ViewerOverlay_MouseDown">
            <Border Width="820" MaxWidth="1000" Height="540" MaxHeight="720" VerticalAlignment="Center"
                    HorizontalAlignment="Center" Background="{DynamicResource Brush.Surface}"
                    BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" CornerRadius="10"
                    MouseLeftButtonDown="ViewerCard_MouseDown">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="16,12,10,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ViewerPath" Grid.Column="0" FontWeight="SemiBold" FontSize="12.5"
                                   FlowDirection="LeftToRight" FontFamily="Consolas, monospace"
                                   TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                        <Button x:Name="ViewerEditBtn" Grid.Column="1" Content="تعديل" Padding="12,5"
                                Click="ViewerEdit_Click"/>
                        <Button x:Name="ViewerSaveBtn" Grid.Column="2" Content="حفظ" Padding="12,5"
                                Visibility="Collapsed" Style="{StaticResource AccentButton}" Click="ViewerSave_Click"/>
                        <Button x:Name="ViewerDownloadBtn" Grid.Column="3" Margin="6,0,0,0" Content="تنزيل…" Padding="12,5"
                                Click="ViewerDownload_Click"/>
                        <Button x:Name="ViewerCopyBtn" Grid.Column="4" Margin="6,0,0,0" Content="نسخ" Padding="12,5"
                                Click="ViewerCopy_Click"/>
                        <Button x:Name="ViewerCloseBtn" Grid.Column="5" Margin="6,0,0,0" Content="&#xE8BB;"
                                FontFamily="Segoe MDL2 Assets" Padding="9,5" Click="ViewerClose_Click"/>
                    </Grid>
                    <ProgressBar x:Name="ViewerLoading" DockPanel.Dock="Top" Height="3" IsIndeterminate="True"
                                 Visibility="Collapsed" Foreground="{DynamicResource Brush.Accent}"
                                 Background="Transparent" BorderThickness="0"/>
                    <TextBlock x:Name="ViewerNote" DockPanel.Dock="Bottom" Margin="16,6,16,10" FontSize="11"
                               TextWrapping="Wrap" Foreground="{DynamicResource Brush.TextMuted}"/>
                    <Border Margin="12,0,12,0" Background="{DynamicResource Brush.Bg}" CornerRadius="6"
                            BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1">
                        <avalon:TextEditor x:Name="ViewerText" IsReadOnly="True" FlowDirection="LeftToRight"
                                           FontFamily="{DynamicResource Font.Mono}" FontSize="12.5"
                                           Background="Transparent" Foreground="{DynamicResource Brush.Text}"
                                           ShowLineNumbers="True" WordWrap="False" Padding="8"
                                           VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <avalon:TextEditor.Resources>
                                <Style TargetType="ScrollBar" BasedOn="{StaticResource ThemedScrollBar}"/>
                            </avalon:TextEditor.Resources>
                        </avalon:TextEditor>
                    </Border>
                </DockPanel>
            </Border>
        </Border>

        <!-- ===== لوحة إدخال نصّ (إعادة تسمية / مجلّد جديد) ===== -->
        <Border x:Name="InputOverlay" Grid.RowSpan="2" Background="#99000000"
                Visibility="Collapsed" MouseLeftButtonDown="InputOverlay_MouseDown">
            <Border Width="450" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Background="{DynamicResource Brush.Surface}" BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1" CornerRadius="12" Padding="24" MouseLeftButtonDown="InputCard_MouseDown">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="28" ShadowDepth="3" Opacity="0.5"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock x:Name="InputTitle" FontSize="19" FontWeight="Bold" Margin="0,0,0,14"
                               Foreground="{DynamicResource Brush.Text}"/>
                    <Grid>
                        <TextBox x:Name="InputBox" VerticalContentAlignment="Center" Padding="10,8" FontSize="13.5"
                                 FlowDirection="LeftToRight" FontFamily="Consolas, monospace"
                                 TextChanged="InputBox_TextChanged" KeyDown="InputBox_KeyDown"/>
                        <!-- نصّ إرشاديّ يظهر حين يكون الحقل فارغاً -->
                        <TextBlock x:Name="InputPlaceholder" IsHitTestVisible="False" VerticalAlignment="Center"
                                   FlowDirection="LeftToRight" Margin="13,0,0,0" FontSize="13.5"
                                   Foreground="{DynamicResource Brush.TextMuted}" Opacity="0.7"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
                        <Button x:Name="InputCancel" Content="إلغاء" Padding="22,10" MinWidth="96"
                                FontSize="13.5" FontWeight="Medium" Click="InputCancel_Click"/>
                        <Button x:Name="InputOk" Content="حفظ" Margin="10,0,0,0" Padding="22,10" MinWidth="96"
                                FontSize="13.5" FontWeight="Medium" IsDefault="True"
                                Style="{StaticResource AccentButton}" Click="InputOk_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
