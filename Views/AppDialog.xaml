<Window x:Class="TerminalLauncher.Views.AppDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" ResizeMode="NoResize" SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        FontFamily="{DynamicResource Font.Ui}" FontSize="{DynamicResource Size.Ui}"
        TextOptions.TextFormattingMode="Ideal">
    <Border Background="{DynamicResource Brush.Surface}" BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="1" CornerRadius="12" Padding="24" Margin="14">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="28" ShadowDepth="3" Opacity="0.5"/>
        </Border.Effect>
        <StackPanel MinWidth="320" MaxWidth="470">
            <TextBlock x:Name="TitleText" FontSize="19" FontWeight="Bold"
                       Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,12"/>
            <ScrollViewer MaxHeight="360" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar" BasedOn="{StaticResource ThemedScrollBar}"/>
                </ScrollViewer.Resources>
                <TextBlock x:Name="MessageText" TextWrapping="Wrap" LineHeight="22" FontSize="13.5"
                           Foreground="{DynamicResource Brush.TextMuted}"/>
            </ScrollViewer>
            <!-- الأزرار مجمّعة على الحافة الأماميّة (يمين في LTR، يسار في RTL) — تتبع اتّجاه اللغة -->
            <StackPanel x:Name="ButtonPanel" Orientation="Horizontal"
                        HorizontalAlignment="Right" Margin="0,24,0,0"/>
        </StackPanel>
    </Border>
</Window>
